<odoo>
   
    <!-- List view -->
    <record id="view_employee_appraisal_list" model="ir.ui.view">
        <field name="name">employee.appraisal.list</field>
        <field name="model">employee.appraisal</field>
        <field name="arch" type="xml">
            <list>
                <field name="employee_id"/>
                <field name="category_id"/>
                <field name="evaluation_type"/>
                <!-- <field name="evaluation_period"/> -->
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="view_employee_appraisal_form" model="ir.ui.view">
        <field name="name">employee.appraisal.form</field>
        <field name="model">employee.appraisal</field>
        <field name="arch" type="xml">
            <form string="Employee Appraisal">
                <header>
                    <button name="action_load_criteria"
                            type="object"
                            string="Load Criteria"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_submit" type="object" string="Submit"
                                 class="btn btn-primary"
                                  invisible="state != 'draft'"
                                />

                   <button name="action_open_remark_wizard_approve"
                                type="object"
                                string="Approve"
                                class="btn btn-success"
                                invisible="state != 'pending' or can_approve == False"/>

                    <button name="action_open_remark_wizard_reject" type="object" string="Reject"
                                class="btn btn-danger"
                                 invisible="state != 'pending' or can_approve == False"/>

                    <button name="action_open_remark_wizard_to_employee"
                                type="object"
                                string="Send to Employee"
                                class="btn btn-warning"
                                 invisible="state != 'under_review' or can_approve == False"/>
                                
                                 

                    <field name="state" readonly="1"/>
                </header>
                <sheet  readonly="state in ('pending','approved','rejected')">
                    <group  readonly="state in ('pending','approved','rejected')">
                        <field name="company_id" readonly="1" options="{'no_open': True}" />
                        <field name="branch_id" readonly ="1" options="{'no_open': True}"  />
                        <field name="department_id" readonly="1" options="{'no_open': True}" />
                        <!-- <field name="job_id" readonly="1" options="{'no_open': True}"  /> -->
                        <field name="employee_id"  readonly="state in ('pending','approved','rejected')" options="{'no_open': True}" />
                        <field name="category_id"   readonly="state in ('pending','approved','rejected')"  options="{'no_open': True}"/>
                        <field name="evaluation_type"   readonly="state in ('pending','approved','rejected')"  options="{'no_open': True}"/>
                        <field name="evaluator_id"   readonly="state in ('pending','approved','rejected')"  options="{'no_open': True}" />
                        <field name="evaluation_start_date" readonly="state != 'draft'"/>
                        <field name="evaluation_end_date"  />
                       
                                                                                                                                                                        
                    </group >
                    <group  readonly="state in ('pending','approved','rejected')">
                        <field name="state" readonly="1"/>
                        <field name="step_progress" widget="html" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Criteria">
                            <field name="criteria_line_ids">
                                <list editable="bottom">
                                    <field name="criteria_id"  readonly="state in ('pending','approved','rejected')" />
                                    <field name="score" widget="rating"   readonly="state in ('pending','approved','rejected')"  options="{'readonly': False}" />
                                    <field name="note"  readonly="state in ('pending','approved','rejected')" />
                                </list>
                            </field>
                        </page>

                        <page string="Remarks History">
                            <field name="remark_ids" nolabel="1">
                                <list>
                                    <field name="date" readonly="1" options="{'no_create': True}"/>
                                    <field name="user_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="job_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="action_type" readonly="1" options="{'no_create': True}"/>
                                    <field name="comment" readonly="1" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                        <page string="Approval Request">
                            <group>
                                <field name="approval_request_id"/>
                                <field name="request_flow_id" readonly="1"/>
                                <field name="request_status" readonly="1"/>
                                <field name="request_requested_by" readonly="1"/>
                            </group>
                            <group>
                                <label for="request_step_progress"/>
                                <field name="request_step_progress" widget="html" readonly="1"/>
                            </group>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <!-- Kanban view for Employee Appraisal -->
    <record id="view_employee_appraisal_kanban" model="ir.ui.view">
        <field name="name">employee.appraisal.kanban</field>
        <field name="model">employee.appraisal</field>
        <field name="arch" type="xml">
            <kanban >
                <field name="employee_id"/>
                <field name="category_id"/>
                <field name="evaluation_type"/>
                <field name="evaluation_start_date"/>
                <field name="evaluation_end_date"/>
                <field name="state"/>
                <field name="department_id"/>

                <templates>
                    <t t-name="card">
                        <div class="o_kanban_card oe_kanban_global_click">

                            <!-- Header -->
                            <div class="o_kanban_record_top o_kanban_primary">
                                <div class="o_kanban_primary_left">
                                    <strong><t t-esc="record.employee_id.value"/></strong>
                                </div>
                                <div class="o_kanban_primary_right">
                                    <span t-att-class="{
                                        'badge': true,
                                        'bg-success': record.state.raw_value == 'approved',
                                        'bg-warning': record.state.raw_value == 'pending',
                                        'bg-secondary': !['approved', 'pending'].includes(record.state.raw_value),
                                    }">
                                        <t t-esc="record.state.value"/>
                                    </span>
                                </div>
                            </div>

                            <!-- Body -->
                            <div class="o_kanban_record_body mt-2">
                                <div><strong>Category:</strong> <t t-esc="record.category_id.value"/></div>
                                <div><strong>Type:</strong> <t t-esc="record.evaluation_type.value"/></div>
                                <div><strong>From:</strong> <t t-esc="record.evaluation_start_date.value"/></div>
                                <div><strong>To:</strong> <t t-esc="record.evaluation_end_date.value"/></div>
                            </div>

                            <!-- Footer -->
                            <div class="o_kanban_footer mt-2 d-flex justify-content-between align-items-center">
                                <div class="text-muted small">
                                    <t t-esc="record.department_id.value"/>
                                </div>
                               
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>




    <!-- Action -->
    <record id="action_employee_appraisal" model="ir.actions.act_window">
        <field name="name">Employee Appraisals</field>
        <field name="res_model">employee.appraisal</field>
        <field name="view_mode">kanban,list,form</field>
    </record>
 
    
 <!-- ✅ Server Action -->
<record id="action_view_my_approval_history_server" model="ir.actions.server">
    <field name="name">My Approval History</field>
    <field name="model_id" ref="model_employee_appraisal"/>
    <field name="state">code</field>
    <field name="code">action = model.action_view_my_appraisals()</field>
</record>

<!-- ✅ Menu Item -->
<menuitem id="menu_my_appraisals"
          name="My Appraisals"
          parent="menu_employee_appraisal_root"
          action="action_view_my_approval_history_server"
          sequence="5"/>

    








</odoo>
