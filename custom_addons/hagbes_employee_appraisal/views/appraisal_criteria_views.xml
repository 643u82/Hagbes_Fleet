<odoo>
   

    <!-- Category List -->
    <record id="view_appraisal_criteria_category_list" model="ir.ui.view">
        <field name="name">appraisal.criteria.category.list</field>
        <field name="model">appraisal.criteria.category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- Category Form -->
    <record id="view_appraisal_criteria_category_form" model="ir.ui.view">
        <field name="name">appraisal.criteria.category.form</field>
        <field name="model">appraisal.criteria.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="criteria_ids">
                            <list editable="bottom">
                                <field name="name"/>
                                <field name="description"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Criteria List -->
    <record id="view_appraisal_criteria_list" model="ir.ui.view">
        <field name="name">appraisal.criteria.list</field>
        <field name="model">appraisal.criteria</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="category_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Criteria Form -->
    <record id="view_appraisal_criteria_form" model="ir.ui.view">
        <field name="name">appraisal.criteria.form</field>
        <field name="model">appraisal.criteria</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="description"/>
                        <field name="category_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action for Categories -->
    <record id="action_appraisal_criteria_category" model="ir.actions.act_window">
        <field name="name">Appraisal Criteria Categories</field>
        <field name="res_model">appraisal.criteria.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Action for Criteria -->
    <record id="action_appraisal_criteria" model="ir.actions.act_window">
        <field name="name">Appraisal Criteria</field>
        <field name="res_model">appraisal.criteria</field>
        <field name="view_mode">list,form</field>
    </record>
   
 <!-- Root menu -->
    <menuitem id="menu_employee_appraisal_root" 
                name="Employee Appraisal" 
                parent="hr.menu_hr_root"/>

    <!-- Submenu for Criteria -->
    <menuitem id="menu_criteria"
              name="Appraisal Criteria"
              parent="menu_employee_appraisal_root"
              action="action_appraisal_criteria_category"/>


</odoo>
