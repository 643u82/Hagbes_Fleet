            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="mrcv_header_comp_rule" model="ir.rule">
            <field name="name">MRCV Header: Multi-Company</field>
            <field name="model_id" ref="model_mrcv_header"/>
