            <field name="domain_force">['|', ('requester_branch_id', '=', False), ('requester_branch_id', 'in', user.allowed_branch_ids.ids)]</field>
        </record>

        <record id="mrv_header_branch_rule" model="ir.rule">
            <field name="name">MRV Header: Branch Security</field>
            <field name="model_id" ref="model_mrv_header"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('requester_branch_id', '=', False), ('requester_branch_id', 'in', user.allowed_branch_ids.ids)]</field>
        </record>

