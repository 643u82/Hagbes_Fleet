<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- ==================== Multi-Company Rules ==================== -->
        <record id="workshop_order_comp_rule" model="ir.rule">
            <field name="name">Workshop Order: Multi-Company</field>
            <field name="model_id" ref="model_workshop_order"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record id="workshop_vehicle_comp_rule" model="ir.rule">
            <field name="name">Workshop Vehicle: Multi-Company</field>
            <field name="model_id" ref="model_workshop_vehicle"/>
