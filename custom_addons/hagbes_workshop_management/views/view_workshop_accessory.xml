<odoo>
<!-- Workshop Accessory Tree View -->
<record id="view_workshop_accessory_tree" model="ir.ui.view">
    <field name="name">workshop.accessory.tree</field>
    <field name="model">workshop.accessory</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="accessory_type"/>
            <field name="categories"/>
            <field name="company_id"/>
            <field name="branch_id"/>
        </list>
    </field>
</record>

<!-- Workshop Accessory Form View -->
<record id="view_workshop_accessory_form" model="ir.ui.view">
    <field name="name">workshop.accessory.form</field>
    <field name="model">workshop.accessory</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="accessory_type"/>
                    <field name="categories"/>
                    <field name="company_id"/>
                    <field name="branch_id"/>
                </group>
            </sheet>
        </form>
    </field>
</record>

<!-- Workshop Accessory Action -->
<record id="action_workshop_accessory" model="ir.actions.act_window">
    <field name="name">Accessories</field>
    <field name="res_model">workshop.accessory</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>