<odoo>
    <record id="view_workshop_vehicle_form" model="ir.ui.view">
        <field name="name">workshop.vehicle.form</field>
        <field name="model">workshop.vehicle</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="category_id"/>
                        <field name="model_id"/>
                        <field name="chassis_number"/>
                        <field name="customer_id"/>
                    </group>
                    <group string="🔧 Engine Information">
                        <field name="engine_make"/>
                        <field name="engine_model"/>
                        <field name="engine_serial"/>
                    </group>
                    <group string="⚙️ Mounted Equipment">
                        <field name="mounted_type"/>
                        <field name="mounted_make"/>
                        <field name="mounted_model"/>
                        <field name="mounted_serial"/>
                    </group>
                    <group>
                        <field name="image" widget="image" class="oe_avatar"/>
                        <field name="company_id"/>
                        <field name="branch_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_workshop_vehicle_tree" model="ir.ui.view">
        <field name="name">workshop.vehicle.tree</field>
        <field name="model">workshop.vehicle</field>
        <field name="arch" type="xml">
            <list>
                <field name="image" widget="image" class="oe_avatar" options="{'size': (50, 50)}"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="model_id"/>
                <field name="chassis_number"/>
                <field name="customer_id"/>
            </list>
        </field>
    </record>
    <record id="action_workshop_vehicle" model="ir.actions.act_window">
        <field name="name">Vehicles</field>
        <field name="res_model">workshop.vehicle</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
