<odoo>
<!-- Vehicle Category Tree View -->
<record id="view_vehicle_category_tree" model="ir.ui.view">
    <field name="name">workshop.vehicle.category.tree</field>
    <field name="model">workshop.vehicle.category</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="type"/>
            <field name="company_id"/>
            <field name="branch_id"/>
        </list>
    </field>
</record>

<!-- Vehicle Category Form View -->
<record id="view_vehicle_category_form" model="ir.ui.view">
    <field name="name">workshop.vehicle.category.form</field>
    <field name="model">workshop.vehicle.category</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="type"/>
                    <field name="company_id"/>
                    <field name="branch_id"/>
                </group>
            </sheet>
        </form>
    </field>
</record>


<!-- Vehicle Category Action -->
<record id="action_vehicle_category" model="ir.actions.act_window">
    <field name="name">Vehicle Categories</field>
    <field name="res_model">workshop.vehicle.category</field>
    <field name="view_mode">list,form</field>
</record>

<!--   Vehicle Category Type-->
    <record id="view_vehicle_category_type_tree" model="ir.ui.view">
    <field name="name">workshop.vehicle.category.type.tree</field>
    <field name="model">workshop.vehicle.category.type</field>
    <field name="arch" type="xml">
        <list>
            <field name="name"/>
            <field name="company_id"/>
            <field name="branch_id"/>
        </list>
    </field>
</record>
    <record id="view_vehicle_category_type_form" model="ir.ui.view">
    <field name="name">workshop.vehicle.category.type.form</field>
    <field name="model">workshop.vehicle.category.type</field>
    <field name="arch" type="xml">
        <form>
            <sheet>
                <group>
                    <field name="name"/>
                    <field name="company_id"/>
                    <field name="branch_id"/>
                </group>
            </sheet>
        </form>
    </field>
</record>
    <!-- Vehicle Category Type Action -->
<record id="action_vehicle_category_type" model="ir.actions.act_window">
    <field name="name">Vehicle Categories Types</field>
    <field name="res_model">workshop.vehicle.category.type</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>
