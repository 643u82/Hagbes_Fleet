<odoo>
  <record id="view_mrv_header_form" model="ir.ui.view">
    <field name="name">mrv.header.form</field>
    <field name="model">mrv.header</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_submit"
                    type="object"
                    string="Submit"
                    class="btn-primary"

                     invisible="state != 'draft'"/>
            <button name="action_approve"
                    string="Approve"
                    type="object"
                    class="btn-success"
                    invisible="state != 'pending' or not is_approver"/>

            <button name="action_reject"
                    string="Reject"
                    type="object"
                    class="btn-danger"
                    invisible="state != 'pending' or not is_approver"
                   />
              </header>
        <sheet>
          <field name="is_approver" invisible="1" />
          <group>
            <field name="name" readonly="1"/>
            <field name="date" readonly="is_approver or state != 'draft'"/>
            <field name="mrcv_id" readonly="is_approver or state != 'draft'"/>
            <field name="requester_branch_id" readonly="is_approver or state != 'draft'"/>
            <field name="issuer_warehouse" readonly="is_approver or state != 'draft'"/>
            <field name="receiver_id" readonly="is_approver or state != 'draft'"/>
            <field name="state" readonly="1"/>
          </group>

          <field name="line_ids" readonly="is_approver or state != 'draft'">
            <list editable="bottom">
              <field name="product_id" readonly="parent.is_approver or parent.state != 'draft'"/>
              <field name="quantity" readonly="parent.is_approver or parent.state != 'draft'"/>
              <field name="uom_id" readonly="parent.is_approver or parent.state != 'draft'"/>
            </list>
          </field>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="view_mrv_header_tree" model="ir.ui.view">
    <field name="name">mrv.header.tree</field>
    <field name="model">mrv.header</field>
    <field name="arch" type="xml">
      <list create="false">
        <field name="name"/>
        <field name="mrcv_id"/>
        <field name="receiver_id"/>
        <field name="date"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="action_mrv_header" model="ir.actions.act_window">
    <field name="name">MRVs</field>
    <field name="res_model">mrv.header</field>
    <field name="view_mode">list,form</field>
  </record>
</odoo>
