<odoo>
  <record id="view_mrcv_header_form" model="ir.ui.view">
    <field name="name">mrcv.header.form</field>
    <field name="model">mrcv.header</field>
    <field name="arch" type="xml">
      <form>
        <field name="state" invisible="1" />
        <field name="job_status" invisible="1" />
        <field name="is_approver" invisible="1" />

        <header>
          <button name="action_submit"
                  type="object"
                  string="Submit"
                  class="btn-primary"

                   invisible="state != 'draft'"/>
          <button name="action_approve"
                  string="Approve"
                  type="object"
                  class="btn-success"
                  invisible="state != 'pending' or not is_approver"/>

          <button name="action_reject"
                  string="Reject"
                  type="object"
                  class="btn-danger"
                  invisible="state != 'pending' or not is_approver"
                 />
           <button name="action_create_mrv"
                string="Create MRV (Return)"
                type="object"
                class="btn-primary"
                invisible="state != 'issued' or job_status == 'closed'"
                />
        </header>

        <sheet>
          <group>
            <field name="name" readonly="1"/>
            <field name="workshop_order_id" readonly="1"/>
            <field name="date" readonly="is_approver or state != 'draft'"/>
            <field name="partner_id" readonly="is_approver or state != 'draft'"/>
            <field name="requester_branch_id" readonly="is_approver or state != 'draft'"/>
            <field name="issuer_warehouse" readonly="is_approver or state != 'draft'"/>
            <field name="state" readonly="1"/>
          </group>
          <field name="line_ids" readonly="is_approver or state != 'draft'">
            <list editable="bottom">
              <field name="product_id" readonly="parent.is_approver or parent.state != 'draft'"/>
              <field name="quantity" readonly="parent.is_approver or parent.state != 'draft'"/>
              <field name="issued_qty" readonly="1"/>
              <field name="uom_id" readonly="parent.is_approver or parent.state != 'draft'"/>
            </list>
          </field>
          <field name="step_progress" widget="html" readonly="1"/>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="view_mrcv_header_tree" model="ir.ui.view">
    <field name="name">mrcv.header.tree</field>
    <field name="model">mrcv.header</field>
    <field name="arch" type="xml">
      <list create="false">
        <field name="name"/>
        <field name="partner_id"/>
        <field name="date"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="action_mrcv_header" model="ir.actions.act_window">
    <field name="name">MRCVs</field>
    <field name="res_model">mrcv.header</field>
    <field name="view_mode">list,form</field>
    <field name="domain">[('workshop_order_id', '!=', False)]</field>
  </record>
</odoo>
