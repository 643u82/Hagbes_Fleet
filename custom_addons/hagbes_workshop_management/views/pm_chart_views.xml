<odoo>
    <!-- Menu -->


    <!-- Action -->
    <record id="workshop_pm_chart_action" model="ir.actions.act_window">
        <field name="name">Preventive Maintenance Charts</field>
        <field name="res_model">workshop.pm.chart</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Chart Tree -->
    <record id="view_pm_chart_tree" model="ir.ui.view">
        <field name="name">pm.chart.tree</field>
        <field name="model">workshop.pm.chart</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="vehicle_model_id"/>
            </list>
        </field>
    </record>

    <!-- Chart Form -->
    <record id="view_pm_chart_form" model="ir.ui.view">
        <field name="name">pm.chart.form</field>
        <field name="model">workshop.pm.chart</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="vehicle_model_id"/>
                    </group>

                    <notebook>
                        <page string="Maintenance Items">
                            <field name="item_ids">
                                <list editable="bottom">
                                    <field name="description"/>
                                    <field name="instruction"/>
                                </list>
                            </field>
                        </page>

                        <page string="Intervals">
                            <field name="item_ids">
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="description" />
                                            <field name="instruction" />
                                        </group>

                                        <field name="interval_line_ids">
                                            <list editable="bottom">
                                                <field name="interval"/>
                                                <field name="action"/>
                                            </list>
                                        </field>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>

</odoo>
