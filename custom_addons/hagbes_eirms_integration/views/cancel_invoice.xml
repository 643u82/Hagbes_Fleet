<odoo>

    <data>
        <record id='view_move_form_cancel_button' model='ir.ui.view'>

            <field name='name'>account.move.form.mor.cancel</field>
            <field name='model'>account.move</field>
            <field name='inherit_id' ref='account.view_move_form'/>
            <field name='arch' type='xml'>
            
                <xpath expr="//button[@name='button_draft']" position='replace'>

                    <button name="action_open_cancel_wizard" 
                            string="Cancel"
                            type='object'
                            class='btn btn-danger'
                            groups='account.group_account_invoice'
                            invisible="state == 'cancel' or not show_reset_to_draft_button"
                            data-hotkey='r'/>


                </xpath>
            
            </field>

        </record>
    </data>

</odoo>