<odoo>
    <record id="view_account_invoice_tree_inherit_hide_create" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.hide.create</field>
            <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
            <field name="arch" type="xml">
            <!-- Disable 'Create' (New) and 'Import' (Upload) in list view -->
            <list position="attributes">
                <attribute name="create">0</attribute>
                <attribute name="import">0</attribute>
            </list>
            </field>
    </record>
    <!-- === FORM VIEW: Hide "New" Button in Top Left === -->
    <record id="view_account_invoice_form_inherit_hide_new_button" model="ir.ui.view">
        <field name="name">account.move.form.inherit.hide.new.button</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Disable 'Create' in form view (hides top-left "New" button) -->
            <form position="attributes">
                <attribute name="create">0</attribute>
            </form>
        </field>
    </record>
</odoo>