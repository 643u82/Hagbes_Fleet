<odoo>
  <record id="view_move_form_inherit_pos_statusbar" model="ir.ui.view">
    <field name="name">account.move.form.inherit.pos.statusbar</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">

      <xpath expr="//field[@name='state']" position="replace">
        <field name="state"
               widget="statusbar"
               statusbar_visible="draft,waiting_pos_print,waiting_fs_number,posted"
               statusbar_colors="draft:gray;waiting_pos_print:orange;waiting_fs_number:blue;posted:green"
               groups="!account.group_account_secured"/>
      </xpath>

    </field>
  </record>
</odoo>
