<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List View -->
    <record id="view_fleet_availability_report_tree" model="ir.ui.view">
        <field name="name">fleet.availability.report.tree</field>
        <field name="model">fleet.availability.report</field>
        <field name="arch" type="xml">
            <list string="Vehicle Availability" create="false" edit="false">
                <field name="vehicle_id"/>
                <field name="plate_number"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="vehicle_status" widget="badge" 
                       decoration-success="vehicle_status == 'available'"
                       decoration-warning="vehicle_status == 'assigned'"
                       decoration-danger="vehicle_status == 'maintenance'"/>
                <field name="driver_name"/>
                <field name="last_trip_date"/>
                <field name="days_idle" decoration-danger="days_idle > 7"/>
                <field name="current_trip_id" optional="show"/>
                <field name="maintenance_status" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_fleet_availability_report_pivot" model="ir.ui.view">
        <field name="name">fleet.availability.report.pivot</field>
        <field name="model">fleet.availability.report</field>
        <field name="arch" type="xml">
            <pivot string="Availability Analysis" sample="1">
                <field name="company_id" type="row"/>
                <field name="vehicle_status" type="col"/>
                <field name="days_idle" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="view_fleet_availability_report_graph" model="ir.ui.view">
        <field name="name">fleet.availability.report.graph</field>
        <field name="model">fleet.availability.report</field>
        <field name="arch" type="xml">
            <graph string="Availability Distribution" type="pie" sample="1">
                <field name="vehicle_status"/>
            </graph>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_fleet_availability_report_search" model="ir.ui.view">
        <field name="name">fleet.availability.report.search</field>
        <field name="model">fleet.availability.report</field>
        <field name="arch" type="xml">
            <search string="Availability Analysis">
                <field name="vehicle_id"/>
                <field name="plate_number"/>
                <filter string="Available Now" name="available" domain="[('vehicle_status', '=', 'available')]"/>
                <filter string="Under Maintenance" name="maintenance" domain="[('vehicle_status', '=', 'maintenance')]"/>
                <filter string="Assigned" name="assigned" domain="[('vehicle_status', '=', 'assigned')]"/>
                <separator/>
                <filter string="Idle > 7 Days" name="idle_7" domain="[('days_idle', '>', 7)]"/>
                <group expand="0" string="Group By">
                    <filter string="Branch" name="group_branch" context="{'group_by':'company_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by':'vehicle_status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_fleet_availability_report" model="ir.actions.act_window">
        <field name="name">Vehicle Availability</field>
        <field name="res_model">fleet.availability.report</field>
        <field name="view_mode">list,pivot,graph</field>
        <field name="search_view_id" ref="view_fleet_availability_report_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No availability data found.
            </p>
        </field>
    </record>
</odoo>
