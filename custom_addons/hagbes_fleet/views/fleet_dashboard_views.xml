
<odoo>
    <!-- OWL client action wrapper for the Fleet Dashboard QWeb template -->
    <record id="action_fleet_dashboard_owl" model="ir.actions.client">
        <field name="name">Fleet Dashboard</field>
        <!-- Must match the tag registered by JS (see static/src/dashboard/dashboard.js) -->
        <field name="tag">hagbes_fleet.Dashboard</field>
    </record>

    <!-- Keep the original external id used by menus/buttons as act_window to avoid XML ID type conflict -->
    <record id="action_fleet_dashboard" model="ir.actions.act_window">
        <field name="name">Fleet Operations Dashboard</field>
        <field name="res_model">fleet.dashboard</field>
        <field name="view_mode">form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Dashboard loaded.
            </p>
        </field>
    </record>
</odoo>



