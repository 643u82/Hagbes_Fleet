<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom CSS for the Dashboard-like Form and Kanban -->
    <record id="view_fleet_requisition_form" model="ir.ui.view">
        <field name="name">fleet.requisition.form</field>
        <field name="model">fleet.requisition</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <form string="Vehicle Requisition">
                <header>
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="oe_highlight"
                            invisible="not can_submit"/>
                    <button name="action_resubmit"
                            string="Resubmit"
                            type="object"
                            class="oe_highlight"
                            invisible="state != 'rejected'"/>
                    
                    <!-- Professional Multi-Stage Workflow Buttons -->
                    <!-- Employee/Requester Actions 
                    <button name="action_submit"
                            string="Submit"
                            type="object"
                            class="btn-primary"
                            invisible="not can_submit"/>   -->

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-secondary"
                            invisible="not can_cancel"/>

                    <button name="action_approve"
                            string="Approve"
                            type="object"
                            class="btn-success"
                            invisible="state != 'submitted'"/>

                    <button name="%(action_fleet_requisition_reject_wizard)d"
                            string="Reject"
                            type="action"
                            class="btn-danger"
                            invisible="state != 'submitted' and state != 'approved'"/>


                    <button name="action_fleet_approve"
                            string="Assign Vehicle"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'approved'"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,submitted,approved,assigned,completed,rejected,cancelled"/>


                </header>

                <sheet>
                    <div class="alert alert-danger" role="alert" invisible="state != 'rejected'">
                        <strong>Rejection Details:</strong><br/>
                        <field name="rejected_by" readonly="1"/> on <field name="rejected_date" readonly="1"/><br/>
                        <strong>Reason:</strong> <field name="rejection_reason" readonly="1"/>

                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group col="2">
                        <group string="Dates" col="2">
                            <field name="date_from"
                                   widget="datetime"
                                   options="{'min_date': 'today'}"
                                   placeholder="Start date and time"
                                   readonly="state != 'draft'"/>
                            <field name="date_to"
                                   widget="datetime"
                                   options="{'min_date': 'today'}"
                                   placeholder="End date and time"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group string="Requester">
                            <field name="request_by"
                                   widget="many2one"
                                   options="{'no_open': True, 'no_create': True}"
                                   readonly="state != 'draft' or not can_edit_requester"/>
                            <field name="department_id"
                                   options="{'no_create': True}"
                                   readonly="1"/>
                            <field name="destination_branch_id"
                                   placeholder="Select destination branch ..."
                                   readonly="state != 'draft'"/>
                            <field name="additional_destination"
                                   placeholder="Additional Destination (if not a branch) ..."
                                   readonly="state != 'draft'"/>
                            <field name="destination"
                                   invisible="1"/>

                        </group>
                    </group>

                    <group string="Purpose">
                        <field name="purpose"
                               nolabel="1"
                               placeholder="A brief reason for request..."
                               readonly="state != 'draft'"/>
                    </group>

                    <group string="Travellers">
                        <field name="traveller_ids"
                               widget="many2many_tags"
                               options="{'no_open': True, 'no_create': True}"
                               readonly="state != 'draft'"/>
                        <field name="traveller_count"
                               readonly="1"/>
                    </group>

                    <group string="Workflow Information" invisible="state == 'draft'">
                        <group>
                            <field name="approved_by" readonly="1" invisible="state != 'approved' and state != 'assigned' and state != 'completed'"/>
                            <field name="approved_date" readonly="1" string="Approved Date" invisible="state != 'approved' and state != 'assigned' and state != 'completed'"/>
                            <field name="fmo_approved_by" readonly="1" invisible="state not in ['assigned', 'completed']"/>
                            <field name="fmo_approved_date" readonly="1" string="FMO Approval Date" invisible="state not in ['assigned', 'completed']"/>
                        </group>

                        <group>
                            <!-- Vehicle info: visible only after FMO/Fleet has assigned the vehicle.
                                 Department managers reviewing a submitted request see no vehicle info;
                                 once approved (state=assigned or later), the assigned vehicle becomes
                                 visible to everyone. This enforces clean role separation. -->
<field name="vehicle_id"
                                   readonly="state in ['assigned', 'completed']"

                                   options="{'no_create': True}"
                                   invisible="state in ['submitted']"/>


                            <field name="vehicle_plate_number"
                                   readonly="1"
                                   invisible="state == 'submitted'"/>
                            <field name="vehicle_driver_name"
                                   readonly="1"
                                   invisible="state == 'submitted'"/>
                        </group>
                    </group>

                    <group string="Operational Execution Info" invisible="state not in ['assigned', 'completed']">

                        <group>
                            <field name="allocation_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="trip_id" readonly="1"/>
                        </group>
                    </group>

                    <!-- Rejection Information (visible only when rejected) -->
                    <group name="rejection_info" string="Rejection Information" invisible="state != 'rejected'">
                        <group>
                            <field name="rejected_by" readonly="1"/>
                            <field name="rejected_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="rejection_reason" readonly="1" nolabel="1"/>
                        </group>
                    </group>

                    <!-- Hidden technical fields -->
                    <field name="can_edit_requester" invisible="1"/>
                    <field name="can_submit" invisible="1"/>
                    <field name="can_dept_approve" invisible="1"/>
                    <field name="can_fmo_approve" invisible="1"/>
                    <field name="can_fleet_approve" invisible="1"/>
                    <field name="can_reject" invisible="1"/>
                    <field name="can_allocate" invisible="1"/>
                    <field name="can_cancel" invisible="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fleet_requisition_tree" model="ir.ui.view">
        <field name="name">fleet.requisition.tree</field>
        <field name="model">fleet.requisition</field>
        <field name="arch" type="xml">
            <list string="Vehicle Requisitions">
                <field name="name"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="purpose"/>
                <field name="traveller_ids" widget="many2many_tags"/>
                <field name="destination"/>
                <field name="request_by"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Dashboard-style Kanban View -->
    <record id="view_fleet_requisition_kanban" model="ir.ui.view">
        <field name="name">fleet.requisition.kanban</field>
        <field name="model">fleet.requisition</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_dashboard" create="true" sample="1" default_order="date_of_request desc">
                <field name="name"/>
                <field name="request_by"/>
                <field name="date_of_request"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="purpose"/>
                <field name="traveller_ids"/>
                <field name="destination"/>
                <field name="department_id"/>
                <field name="state"/>
                <field name="company_id"/>
                <field name="vehicle_id"/>
                <field name="vehicle_plate_number"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click p-0 m-2 border-0 shadow-sm" style="width: 350px; border-radius: 4px; overflow: hidden;">
                            <!-- Card Header: Company/Branch -->
                            <div class="bg-primary text-white p-2" style="background-color: #71b1f1 !important;">
                                <strong class="fs-5"><field name="company_id"/></strong>
                            </div>
                            
                            <!-- Card Body -->
                            <div class="p-3 bg-white text-dark">
                                <div class="mb-1"><strong>Date of Request:</strong> <field name="date_of_request"/></div>
                                <div class="mb-1"><strong>For Date:</strong> <field name="date_from"/></div>
                                <div class="mb-1"><strong>From To:</strong> <field name="date_from" widget="datetime"/> - <field name="date_to" widget="datetime"/></div>
                                <div class="mb-1 text-truncate"><strong>Purpose:</strong> <field name="purpose"/></div>
                                <div class="mb-1"><strong>Travellers:</strong> <field name="traveller_ids" widget="many2many_tags"/></div>
                                <div class="mb-1"><strong>Destination:</strong> <field name="destination"/></div>
                                <div class="mb-1"><strong>Request By:</strong> <field name="request_by"/></div>
                                <div class="mb-1"><strong>Department:</strong> <field name="department_id"/></div>
                                <div class="mb-1" invisible="not vehicle_id">
                                    <strong>Vehicle:</strong> <field name="vehicle_id"/> (<field name="vehicle_plate_number"/>)
                                </div>
                                
                                <!-- Operations Footer -->
                                <div class="d-flex align-items-center mt-3 border-top pt-2">
                                    <strong class="mr-2">Ops:</strong>
                                    <button name="action_submit" type="object" class="btn btn-primary btn-sm mr-1 py-0 px-2" invisible="not can_submit">
                                        Submit
                                    </button>
                    <button name="action_approve" type="object" class="btn btn-success btn-sm mr-1 py-0 px-2" invisible="not can_dept_approve and not can_fmo_approve">

                                        Approve
                                    </button>
                                    <button name="action_cancel" type="object" class="btn btn-danger btn-sm py-0 px-1" title="Cancel" invisible="not can_cancel">
                                        <i class="fa fa-trash-o" title="Cancel"/>
                                    </button>
                                    <div class="ml-auto">
                                        <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'submitted': 'warning', 'approved': 'warning', 'assigned': 'success', 'completed': 'success', 'rejected': 'danger', 'cancelled': 'secondary'}}"/>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_fleet_requisition_search" model="ir.ui.view">
        <field name="name">fleet.requisition.search</field>
        <field name="model">fleet.requisition</field>
        <field name="arch" type="xml">
            <search string="Search Requisitions">
                <field name="name"/>
                <field name="request_by"/>
                <field name="department_id"/>
                <field name="destination"/>
                <filter string="My Requisitions" name="my_requisitions" domain="[('request_by', '=', uid)]"/>
                <filter string="Travelling With Me" name="travelling_with_me" domain="[('traveller_ids', 'in', uid)]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Dept Approved" name="dept_approved" domain="[('state', '=', 'dept_approved')]"/>

                <filter string="Assigned" name="assigned" domain="[('state', '=', 'assigned')]"/>

                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Requester" name="group_by_requester" context="{'group_by': 'request_by'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_by_date" context="{'group_by': 'date_of_request'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_fleet_requisition" model="ir.actions.act_window">
        <field name="name">List of Requests</field>
        <field name="res_model">fleet.requisition</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'form_view_ref': 'hagbes_fleet.view_fleet_requisition_form'}</field>
        <field name="search_view_id" ref="view_fleet_requisition_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new vehicle requisition.
            </p>
        </field>
    </record>

    <!-- Explicit View Mapping for Requisitions -->
    <record id="action_fleet_requisition_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_fleet_requisition_kanban"/>
        <field name="act_window_id" ref="action_fleet_requisition"/>
    </record>

    <record id="action_fleet_requisition_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_fleet_requisition_tree"/>
        <field name="act_window_id" ref="action_fleet_requisition"/>
    </record>

    <record id="action_fleet_requisition_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="3"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_fleet_requisition_form"/>
        <field name="act_window_id" ref="action_fleet_requisition"/>
    </record>

    <!-- Dept Manager Approval Action: shows only submitted requests (dept filter via record rule) -->
    <record id="action_fleet_requisition_dept_approval" model="ir.actions.act_window">
        <field name="name">Pending Approvals</field>
        <field name="res_model">fleet.requisition</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="domain">['|', ('state', 'in', ['submitted', 'dept_approved']), '&amp;', ('state', '=', 'draft'), ('request_by', '=', uid)]</field>

        <field name="context">{
            'form_view_ref': 'hagbes_fleet.view_fleet_requisition_form',
            'search_default_submitted': 1,
            'search_default_dept_approved': 1,

            'search_default_draft': 1
        }</field>
        <field name="search_view_id" ref="view_fleet_requisition_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No pending requisitions to approve.
            </p>
            <p>Submitted requests from your department will appear here for your review.</p>
        </field>
    </record>

    <record id="action_fleet_requisition_dept_approval_view_kanban" model="ir.actions.act_window.view">
        <field name="sequence" eval="0"/>
        <field name="view_mode">kanban</field>
        <field name="view_id" ref="view_fleet_requisition_kanban"/>
        <field name="act_window_id" ref="action_fleet_requisition_dept_approval"/>
    </record>

    <record id="action_fleet_requisition_dept_approval_view_list" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_fleet_requisition_tree"/>
        <field name="act_window_id" ref="action_fleet_requisition_dept_approval"/>
    </record>

    <record id="action_fleet_requisition_dept_approval_view_form" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_fleet_requisition_form"/>
        <field name="act_window_id" ref="action_fleet_requisition_dept_approval"/>
    </record>

    <!-- Menu items are defined in fleet_menu.xml -->
</odoo>
