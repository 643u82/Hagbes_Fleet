<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- KPI Summary List View (Leaderboard) -->
        <record id="view_fleet_driver_kpi_list" model="ir.ui.view">
            <field name="name">fleet.driver.kpi.list</field>
            <field name="model">fleet.driver.kpi</field>
            <field name="arch" type="xml">
                <list string="Driver Leaderboard" default_order="rank asc, total_score desc" create="false" edit="false">
                    <field name="rank" widget="handle"/>
                    <field name="driver_id"/>
                    <field name="period"/>
                    <field name="total_score" widget="progressbar" string="Overall Score"/>
                    <field name="fuel_score"/>
                    <field name="distance_score"/>
                    <field name="time_score"/>
                    <field name="compliance_score"/>
                </list>
            </field>
        </record>

        <!-- KPI Summary Form View -->
        <record id="view_fleet_driver_kpi_form" model="ir.ui.view">
            <field name="name">fleet.driver.kpi.form</field>
            <field name="model">fleet.driver.kpi</field>
            <field name="arch" type="xml">
                <form string="Driver Performance Details" create="false" edit="false">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="driver_id" readonly="1"/>
                            </h1>
                            <h2>
                                Period: <field name="period" readonly="1"/> | Rank: #<field name="rank" readonly="1"/>
                            </h2>
                        </div>
                        <group>
                            <group>
                                <field name="total_score" widget="gauge" options="{'max_field': 100}"/>
                                <field name="computed_date" readonly="1"/>
                            </group>
                            <group>
                                <field name="fuel_score" widget="progressbar"/>
                                <field name="distance_score" widget="progressbar"/>
                                <field name="time_score" widget="progressbar"/>
                                <field name="compliance_score" widget="progressbar"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Trip Details">
                                <field name="line_ids" readonly="1">
                                    <list>
                                        <field name="trip_id"/>
                                        <field name="total_score"/>
                                        <field name="fuel_score"/>
                                        <field name="distance_score"/>
                                        <field name="time_score"/>
                                        <field name="compliance_score"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- KPI Graph View -->
        <record id="view_fleet_driver_kpi_graph" model="ir.ui.view">
            <field name="name">fleet.driver.kpi.graph</field>
            <field name="model">fleet.driver.kpi</field>
            <field name="arch" type="xml">
                <graph string="Driver Performance Comparison" type="bar">
                    <field name="driver_id" type="row"/>
                    <field name="total_score" type="measure"/>
                </graph>
            </field>
        </record>

        <!-- Action -->
        <record id="action_fleet_driver_kpi" model="ir.actions.act_window">
            <field name="name">Driver Performance</field>
            <field name="res_model">fleet.driver.kpi</field>
            <field name="view_mode">list,form,graph</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                No performance records computed yet.
              </p>
              <p>
                Driver scores will automatically generate at the end of the day based on completed trips.
              </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_fleet_driver_kpi" 
                  name="Driver Performance" 
                  parent="menu_fleet_reports" 
                  action="action_fleet_driver_kpi" 
                  sequence="60"/>
    </data>
</odoo>
