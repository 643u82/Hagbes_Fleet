<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Assignment Views -->
    <record id="view_fleet_vehicle_assign_tree" model="ir.ui.view">
        <field name="name">hagbes.fleet.vehicle.assign.tree</field>
        <field name="model">hagbes.fleet.vehicle.assign</field>
        <field name="arch" type="xml">
            <list string="Assignments">
                <field name="vehicle_id"/>
                <field name="employee_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_vehicle_assign_form" model="ir.ui.view">
        <field name="name">hagbes.fleet.vehicle.assign.form</field>
        <field name="model">hagbes.fleet.vehicle.assign</field>
        <field name="arch" type="xml">
            <form string="Vehicle Assignment">
                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete"
                            type="object"
                            string="Complete"
                            invisible="state != 'active'"/>
                    <button name="action_force_activate"
                            type="object"
                            string="Force Activate (Admin)"
                            class="btn-danger"
                            groups="hagbes_fleet.group_fleet_admin"
                            invisible="state != 'pending' or not is_approval_disabled_or_missing"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,active,completed,rejected"/>
                </header>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="employee_id"/>
                        <field name="start_date"/>
                        <field name="end_date"/>
                        <field name="is_approval_disabled_or_missing" invisible="1"/>
                    </group>
                    <group>
                        <field name="notes" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_assignment" model="ir.actions.act_window">
        <field name="name">Assignments</field>
        <field name="res_model">hagbes.fleet.vehicle.assign</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
