<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vehicle Status Log Tree View -->
    <record id="view_fleet_vehicle_status_log_tree" model="ir.ui.view">
        <field name="name">hagbes.fleet.vehicle.status.log.tree</field>
        <field name="model">hagbes.fleet.vehicle.status.log</field>
        <field name="arch" type="xml">
            <list string="Vehicle Status Logs" default_order="date desc">
                <field name="date" string="Date"/>
                <field name="vehicle_id" string="Vehicle"/>
                <field name="odometer" string="Odometer (km)"/>
                <field name="fuel_level" string="Fuel Level"/>
                <field name="condition_notes" string="Condition Notes"/>
            </list>
        </field>
    </record>

    <!-- Vehicle Status Log Form View -->
    <record id="view_fleet_vehicle_status_log_form" model="ir.ui.view">
        <field name="name">hagbes.fleet.vehicle.status.log.form</field>
        <field name="model">hagbes.fleet.vehicle.status.log</field>
        <field name="arch" type="xml">
            <form string="Vehicle Status Log">
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id" options="{'no_create': True}"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="odometer"/>
                            <field name="fuel_level"/>
                        </group>
                    </group>
                    <group>
                        <field name="condition_notes" placeholder="Enter any observations about vehicle condition, maintenance needs, or other notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vehicle Status Log Search View -->
    <record id="view_fleet_vehicle_status_log_search" model="ir.ui.view">
        <field name="name">hagbes.fleet.vehicle.status.log.search</field>
        <field name="model">hagbes.fleet.vehicle.status.log</field>
        <field name="arch" type="xml">
            <search string="Vehicle Status Logs">
                <field name="vehicle_id" string="Vehicle"/>
                <field name="date" string="Date"/>
                <field name="condition_notes" string="Condition Notes"/>
                <separator/>
                <filter name="today" string="Today" domain="[('date', '=', context_today().strftime('%Y-%m-%d'))]"/>
                <filter name="this_week" string="This Week" domain="[('date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                <filter name="this_month" string="This Month" domain="[('date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="group_by_vehicle" string="Vehicle" context="{'group_by': 'vehicle_id'}"/>
                    <filter name="group_by_date" string="Date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vehicle Status Log Action -->
    <record id="action_fleet_vehicle_status_log" model="ir.actions.act_window">
        <field name="name">Vehicle Status Logs</field>
        <field name="res_model">hagbes.fleet.vehicle.status.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fleet_vehicle_status_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a vehicle status log
            </p>
            <p>
                Vehicle status logs capture daily snapshots of vehicle odometer readings,
                fuel levels, and condition notes for audit and maintenance planning.
            </p>
        </field>
    </record>
</odoo>