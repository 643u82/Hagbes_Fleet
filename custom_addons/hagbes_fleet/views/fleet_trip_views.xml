<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_trip_form" model="ir.ui.view">
        <field name="name">fleet.trip.form</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <form string="Fleet Trip">
                <header>
                    <button name="action_start_trip" string="Start Trip" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_record_actual_data" string="Record Return Data" type="object" class="oe_highlight" invisible="state != 'started'"/>
                    <button name="action_cancel_trip" string="Cancel Trip" type="object" groups="hagbes_fleet.group_fleet_admin" invisible="state not in ['draft', 'started']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,started,completed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_requisitions" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="requisition_count" widget="statinfo" string="Requisitions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Info">
                            <field name="allocation_id" invisible="1"/>
                            <field name="vehicle_id"/>
                            <field name="driver_name"/>
                            <field name="plate_number"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Planning Info">
                            <field name="allocation_date"/>
                            <field name="allocated_by" readonly="1"/>
                            <field name="start_location"/>
                        </group>
                    </group>
                    <group>
                        <group string="Planned Distance &amp; Fuel">
                            <field name="planned_route_distance"/>
                            <field name="km_at_start"/>
                            <field name="fuel_at_start"/>
                            <field name="km_per_liter"/>
                            <field name="fuel_for_route"/>
                        </group>
                        <group string="Status Indicators">
                            <field name="discrepancy_status" widget="badge" decoration-danger="discrepancy_status == 'flagged'" decoration-success="discrepancy_status == 'resolved'"/>
                            <field name="odometer_gap_flag" invisible="1"/>
                            <div class="alert alert-danger" role="alert" invisible="not odometer_gap_flag">
                                <strong>Warning!</strong> Odometer gap detected: <field name="odometer_gap"/> KM.
                            </div>
                        </group>
                    </group>
                    <notebook>
                        <page string="Actual Data" invisible="state == 'planning'">
                            <group>
                                <group string="Return Info">
                                    <field name="return_date"/>
                                    <field name="return_time" widget="float_time"/>
                                    <field name="actual_start_place"/>
                                    <field name="actual_destination"/>
                                    <field name="signed_by"/>
                                </group>
                                <group string="Actual Odometer">
                                    <field name="km_at_start_actual"/>
                                    <field name="km_at_end_actual"/>
                                    <field name="transport_km"/>
                                    <field name="actual_distance"/>
                                    <field name="prev_trip_km_end"/>
                                </group>
                            </group>
                            <group string="Discrepancy Details">
                                <group>
                                    <field name="distance_difference"/>
                                    <field name="distance_difference_pct"/>
                                </group>
                                <group>
                                    <field name="discrepancy_reason"/>
                                </group>
                            </group>
                        </page>
                        <page string="GPS Data" groups="hagbes_fleet.group_fmo,hagbes_fleet.group_fleet_admin">
                            <group>
                                <group string="GPS Readings">
                                    <field name="gps_distance"/>
                                    <field name="gps_km_at_end"/>
                                    <field name="gps_fuel_at_end"/>
                                    <field name="gps_fuel_consumed"/>
                                </group>
                                <group string="Analysis">
                                    <field name="unauthorized_stops"/>
                                </group>
                            </group>
                        </page>
                        <page string="Requisitions">
                            <field name="requisition_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fleet_trip_tree" model="ir.ui.view">
        <field name="name">fleet.trip.tree</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <list string="Fleet Trips" decoration-info="state == 'draft'" decoration-warning="state == 'started'">
                <field name="name"/>
                <field name="allocation_date"/>
                <field name="vehicle_id"/>
                <field name="driver_name"/>
                <field name="start_location"/>
                <field name="actual_distance"/>
                <field name="discrepancy_status" widget="badge" decoration-danger="discrepancy_status == 'flagged'" decoration-success="discrepancy_status == 'resolved'"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_fleet_trip" model="ir.actions.act_window">
        <field name="name">Fleet Trips</field>
        <field name="res_model">fleet.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage vehicle trips and allocations.
            </p>
        </field>
    </record>
</odoo>
