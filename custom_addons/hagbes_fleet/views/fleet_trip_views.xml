<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_fleet_trip_form" model="ir.ui.view">
        <field name="name">fleet.trip.form</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <form string="Fleet Trip">
                <header>
                    <button name="action_confirm_planning" string="Confirm Planning" type="object" class="btn-primary" invisible="state not in ['draft','planned']"/>
                    <button name="action_approve_planning" string="Approve" type="object" class="btn-primary" invisible="state != 'planned'"/>
                    <button name="action_dispatch" string="Dispatch" type="object" class="btn-primary" invisible="state != 'approved'"/>
                    <button name="action_start_trip" string="Start Trip" type="object" class="oe_highlight" invisible="state != 'dispatched'"/>
                    <button name="action_record_actual_data" string="Record Return Data" type="object" class="oe_highlight" invisible="state != 'in_progress'"/>
                    <button name="action_reset_to_draft" string="Reset to Draft" type="object" groups="hagbes_fleet.group_fleet_admin" invisible="state == 'draft'"/>
                    <button name="action_cancel_trip" string="Cancel Trip" type="object" groups="hagbes_fleet.group_fleet_admin" invisible="state in ['done','cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,planned,approved,dispatched,in_progress,done"/>


                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_requisitions" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="requisition_count" widget="statinfo" string="Requisitions"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Basic Info">
                            <field name="allocation_id" invisible="1"/>
                            <field name="vehicle_id"/>
                            <field name="driver_name"/>
                            <field name="plate_number"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Planning Info">
                            <field name="allocation_date" readonly="state not in ['draft','planned','approved']"/>
                            <field name="allocated_by" readonly="1"/>
                            <field name="start_location" readonly="state not in ['draft','planned','approved']"/>
                        </group>

                    </group>
                    <group>
                        <group string="Planned Distance &amp; Fuel" invisible="state in ['dispatched','in_progress','done']">
                            <field name="planned_route_distance" readonly="state not in ['draft','planned']"/>
                            <field name="km_per_liter" readonly="state not in ['draft','planned']"/>
                            <field name="fuel_for_route" readonly="1"/>
                        </group>
                        <group string="Dispatch/Execution (locked planning)" invisible="state not in ['dispatched','in_progress','done']">
                            <field name="km_at_start" invisible="1"/>
                            <field name="fuel_at_start" readonly="1"/>
                        </group>
                        <group string="Completion Analytics" invisible="state not in ['done']">
                            <field name="discrepancy_status" widget="badge" decoration-danger="discrepancy_status == 'flagged'" decoration-success="discrepancy_status == 'resolved'"/>
                            <field name="odometer_gap_flag" invisible="1"/>
                            <div class="alert alert-danger" role="alert" invisible="not odometer_gap_flag">
                                <strong>Warning!</strong> Odometer gap detected: <field name="odometer_gap"/> KM.
                            </div>
                        </group>

                    </group>

                    <!-- Trip planning stops (multiple destinations) -->
                    <group string="Trip Planning" invisible="state not in ['planned','approved']">

                        <group>
                            <field name="stops_ids" widget="one2many_list" context="{'default_trip_id': id}"/>
                        </group>
                    </group>

<group string="Dispatch &amp; Execution" invisible="state not in ['dispatched','in_progress']">
                        <group>
                            <group string="Dispatch Inputs">
                                <field name="km_at_start_actual" readonly="state != 'dispatched'"/>
                                <field name="fuel_at_start" readonly="1"/>
                            </group>
                        </group>
                        <group string="Execution Notes">
                            <field name="stops_ids" widget="one2many_list" readonly="1" invisible="1"/>
                        </group>
                    </group>

                    <group string="Completion / Analytics" invisible="state != 'done'">
                        <group>
                            <group string="Return Info">
                                <field name="return_date" readonly="1"/>
                                <field name="return_time" readonly="1"/>
                                <field name="actual_start_place" readonly="1"/>
                                <field name="actual_destination" readonly="1"/>
                                <field name="signed_by" readonly="1"/>
                            </group>
<group string="Actual Odometer &amp; Fuel">
                                <field name="km_at_start_actual" readonly="1"/>
                                <field name="km_at_end_actual" readonly="1"/>
                                <field name="transport_km" readonly="1"/>
                                <field name="actual_distance" readonly="1"/>
                                <field name="fuel_used_l" readonly="1"/>
                                <field name="distance_travelled_km" readonly="1"/>
                                <field name="fuel_efficiency_km_per_l" readonly="1"/>
                            </group>
                        </group>
                        <group string="Additional Places">
                            <field name="additional_place_ids" widget="one2many_list" readonly="1">
                                <list>
                                    <field name="place_name" readonly="1"/>
                                    <field name="km_used" readonly="1"/>
                                </list>
                            </field>
                        </group>
                        <group string="Discrepancy Details">
                            <group>
                                <field name="distance_difference" readonly="1"/>
                                <field name="distance_difference_pct" readonly="1"/>
                            </group>
                            <group>
                                <field name="discrepancy_reason" readonly="1"/>
                            </group>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="view_fleet_trip_tree" model="ir.ui.view">
        <field name="name">fleet.trip.tree</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <list string="Fleet Trips" decoration-info="state == 'draft'" decoration-warning="state == 'started'">
                <field name="name"/>
                <field name="allocation_date"/>
                <field name="vehicle_id"/>
                <field name="driver_name"/>
                <field name="start_location"/>
                <field name="actual_distance"/>
                <field name="discrepancy_status" widget="badge" decoration-danger="discrepancy_status == 'flagged'" decoration-success="discrepancy_status == 'resolved'"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_fleet_trip" model="ir.actions.act_window">
        <field name="name">Fleet Trips</field>
        <field name="res_model">fleet.trip</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage vehicle trips and allocations.
            </p>
        </field>
    </record>
</odoo>
