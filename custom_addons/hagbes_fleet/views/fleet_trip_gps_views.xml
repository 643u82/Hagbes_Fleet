<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- GPS Point Tree View -->
    <record id="view_fleet_trip_gps_tree" model="ir.ui.view">
        <field name="name">hagbes.fleet.trip.gps.tree</field>
        <field name="model">hagbes.fleet.trip.gps</field>
        <field name="arch" type="xml">
            <list string="GPS Points" default_order="timestamp asc">
                <field name="timestamp"/>
                <field name="latitude" widget="float" digits="[10,6]"/>
                <field name="longitude" widget="float" digits="[10,6]"/>
                <field name="trip_id"/>
            </list>
        </field>
    </record>

    <!-- GPS Point Form View -->
    <record id="view_fleet_trip_gps_form" model="ir.ui.view">
        <field name="name">hagbes.fleet.trip.gps.form</field>
        <field name="model">hagbes.fleet.trip.gps</field>
        <field name="arch" type="xml">
            <form string="GPS Point">
                <sheet>
                    <group>
                        <group>
                            <field name="trip_id"/>
                            <field name="timestamp"/>
                        </group>
                        <group>
                            <field name="latitude" widget="float" digits="[10,6]"/>
                            <field name="longitude" widget="float" digits="[10,6]"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- GPS Point Search View -->
    <record id="view_fleet_trip_gps_search" model="ir.ui.view">
        <field name="name">hagbes.fleet.trip.gps.search</field>
        <field name="model">hagbes.fleet.trip.gps</field>
        <field name="arch" type="xml">
            <search string="GPS Points">
                <field name="trip_id"/>
                <field name="timestamp"/>
                <filter string="Today" name="today" 
                        domain="[('timestamp', '>=', datetime.datetime.combine(context_today(), datetime.time(0,0,0))),
                                ('timestamp', '&lt;', datetime.datetime.combine(context_today() + datetime.timedelta(days=1), datetime.time(0,0,0)))]"/>
                <filter string="This Week" name="this_week"
                        domain="[('timestamp', '>=', (context_today() - datetime.timedelta(days=context_today().weekday())).strftime('%Y-%m-%d')),
                                ('timestamp', '&lt;', (context_today() + datetime.timedelta(days=7-context_today().weekday())).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Trip" name="group_trip" context="{'group_by': 'trip_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'timestamp:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- GPS Point Action -->
    <record id="action_fleet_trip_gps" model="ir.actions.act_window">
        <field name="name">GPS Points</field>
        <field name="res_model">hagbes.fleet.trip.gps</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_fleet_trip_gps_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a GPS point record
            </p>
            <p>
                GPS points track the location coordinates for trips, providing
                route tracking and audit capabilities.
            </p>
        </field>
    </record>
</odoo>