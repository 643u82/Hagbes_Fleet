<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Maintenance Views -->
    <record id="view_fleet_maintenance_tree" model="ir.ui.view">
        <field name="name">hagbes.fleet.maintenance.tree</field>
        <field name="model">hagbes.fleet.maintenance</field>
        <field name="arch" type="xml">
            <list string="Maintenance Records">
                <field name="vehicle_id"/>
                <field name="service_type"/>
                <field name="service_date"/>
                <field name="cost"/>
                <field name="product_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_fleet_maintenance_form" model="ir.ui.view">
        <field name="name">hagbes.fleet.maintenance.form</field>
        <field name="model">hagbes.fleet.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Record">
                <header>
                    <button name="action_submit"
                            type="object"
                            string="Submit"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete"
                            type="object"
                            string="Complete"
                            invisible="state != 'active'"/>
                    <button name="action_force_activate"
                            type="object"
                            string="Force Activate (Admin)"
                            class="btn-danger"
                            groups="hagbes_fleet.group_fleet_admin"
                            invisible="state != 'pending' or not is_approval_disabled_or_missing"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,active,completed,rejected"/>
                </header>
                <sheet>
                    <group>
                        <field name="vehicle_id"/>
                        <field name="service_type"/>
                        <field name="service_date"/>
                        <field name="product_id"/>
                        <field name="cost"/>
                        <field name="is_approval_disabled_or_missing" invisible="1"/>
                    </group>
                    <group string="Description">
                        <field name="description" colspan="2"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fleet_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance</field>
        <field name="res_model">hagbes.fleet.maintenance</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
