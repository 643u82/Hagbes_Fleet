<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="hagbes_fleet.Dashboard" owl="1">
        <div class="o_dashboards_view o_action px-4 py-3 bg-100 overflow-auto">
            <div class="mb-4 pb-3 border-bottom bg-white p-4 rounded shadow-sm">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                    <div>
                        <h3 class="m-0 fw-bold" style="color: #017e84;">Fleet Overview</h3>
                        <div class="text-muted mt-1 small d-flex align-items-center gap-2">
                            <i class="fa fa-building"/>
                            <span class="fw-semibold">Hagbes Plc</span>
                            <span class="text-muted">-</span>
                            <span>
                                <span t-esc="new Date().toLocaleDateString()"/>
                            </span>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        <button type="button"
                                t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_utilization_report')"
                                class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <span>Utilization</span>
                        </button>
                        <button type="button"
                                t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_availability_report')"
                                class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <span>Availability</span>
                        </button>
                        <button type="button"
                                t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_maintenance_history_report')"
                                class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <span>Maintenance</span>
                        </button>
                        <button type="button"
                                t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_maintenance_due_report')"
                                class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <span>Due</span>
                        </button>
                        <button type="button"
                                t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_allocation_report')"
                                class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                            <span>Allocation</span>
                        </button>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <!-- Primary KPIs (Neutral) -->
                <div class="col-12">
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Total Vehicles</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.total_vehicles">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Total Trips</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.total_trips">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Total Fleet Distance</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.total_fleet_distance">0</div>
                                    <div class="text-muted small mt-1">KM</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Allocation Count</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.allocation_count">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Success KPIs (Green) -->
                <div class="col-12">
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-success">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Available Vehicles</div>
                                    <div class="font-monospace text-success" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.available_vehicles">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-primary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Active Allocations</div>
                                    <div class="font-monospace text-primary" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.active_allocations">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Average Distance</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.average_distance">0</div>
                                    <div class="text-muted small mt-1">KM</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-warning">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Total Maintenance Events</div>
                                    <div class="font-monospace text-warning" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.total_maintenance_events">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Warning / Danger KPIs -->
                <div class="col-12">
                    <div class="row g-4">
                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-warning">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Vehicles In Maintenance</div>
                                    <div class="font-monospace text-warning" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.in_maintenance_vehicles">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-danger">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Out Of Service Vehicles</div>
                                    <div class="font-monospace text-danger" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.out_of_service_vehicles">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-warning">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Vehicles Due</div>
                                    <div class="font-monospace text-warning" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.vehicles_due">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-danger">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Vehicles Overdue</div>
                                    <div class="font-monospace text-danger" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.vehicles_overdue">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-danger">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Total Maintenance Cost</div>
                                    <div class="font-monospace text-danger" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.total_maintenance_cost">0</div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-12 d-flex">
                            <div class="card shadow-sm border-0 h-100 w-100 border-start border-3 border-secondary">
                                <div class="card-body text-center p-4 o_dashboard_kpi_hover">
                                    <div class="text-muted small fw-bold text-uppercase">Allocated Vehicles</div>
                                    <div class="font-monospace" style="font-size: 2.2rem; font-weight: 800; line-height: 1;" t-esc="metrics.allocated_vehicles">0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Footer spacer for enterprise polish -->
                <div class="col-12">
                    <div class="card shadow-sm border-0 bg-white p-4">
                        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                            <div>
                                <div class="text-uppercase text-muted small fw-semibold">Quick Actions</div>
                                <div class="text-muted small mt-1">Open analytical dashboards for deeper insights.</div>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <button type="button"
                                        t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_utilization_report')"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    Utilization
                                </button>
                                <button type="button"
                                        t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_availability_report')"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    Availability
                                </button>
                                <button type="button"
                                        t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_maintenance_history_report')"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    Maintenance
                                </button>
                                <button type="button"
                                        t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_maintenance_due_report')"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    Due
                                </button>
                                <button type="button"
                                        t-on-click="() => this._onOpenReport('hagbes_fleet.action_fleet_allocation_report')"
                                        class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                    Allocation
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <style>
            .o_dashboard_kpi_hover:hover{transform: translateY(-2px); box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.08)!important;}
            .o_dashboards_view{min-height: 400px;}
        </style>
    </t>
</templates>


