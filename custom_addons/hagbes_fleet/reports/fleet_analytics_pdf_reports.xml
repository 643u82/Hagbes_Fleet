<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Maintenance History PDF Template -->
        <template id="report_maintenance_history">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="header">
                            <h2 class="text-center">Maintenance History Analysis</h2>
                            <p class="text-center">Generated on <span t-esc="context_today().strftime('%d/%m/%Y')"/></p>
                        </div>

                        <table class="table table-sm table-bordered mt-4">
                            <thead style="background-color: #f5f5f5;">
                                <tr>
                                    <th>Vehicle</th>
                                    <th>Branch</th>
                                    <th>Service Type</th>
                                    <th class="text-end">Count</th>
                                    <th class="text-end">Total Cost</th>
                                    <th class="text-end">Avg Cost</th>
                                    <th>Last Service</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="o">
                                    <tr>
                                        <td><span t-field="o.vehicle_id.name"/></td>
                                        <td><span t-field="o.company_id.name"/></td>
                                        <td><span t-field="o.service_type"/></td>
                                        <td class="text-end"><span t-field="o.maintenance_count"/></td>
                                        <td class="text-end"><span t-field="o.total_cost" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td class="text-end"><span t-field="o.avg_cost" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td><span t-field="o.last_service_date"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>

        <!-- Vehicle Allocation PDF Template -->
        <template id="report_allocation_analysis">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="header">
                            <h2 class="text-center">Vehicle Allocation Analysis</h2>
                            <p class="text-center">Generated on <span t-esc="context_today().strftime('%d/%m/%Y')"/></p>
                        </div>

                        <table class="table table-sm table-bordered mt-4">
                            <thead style="background-color: #f5f5f5;">
                                <tr>
                                    <th>Vehicle</th>
                                    <th>Branch</th>
                                    <th>Driver</th>
                                    <th class="text-end">Allocations</th>
                                    <th class="text-end">Active</th>
                                    <th class="text-end">Total Planned KM</th>
                                    <th>Last Allocation</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="o">
                                    <tr>
                                        <td><span t-field="o.vehicle_id.name"/></td>
                                        <td><span t-field="o.company_id.name"/></td>
                                        <td><span t-field="o.driver_id.name"/></td>
                                        <td class="text-end"><span t-field="o.allocation_count"/></td>
                                        <td class="text-end"><span t-field="o.active_allocations"/></td>
                                        <td class="text-end"><span t-field="o.total_planned_distance" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td><span t-field="o.last_allocation_date" t-options='{"widget": "date"}'/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>

        <!-- PDF Report Actions -->
        <record id="action_report_maintenance_history_analysis" model="ir.actions.report">
            <field name="name">Maintenance History Analysis</field>
            <field name="model">fleet.maintenance.history.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hagbes_fleet.report_maintenance_history</field>
            <field name="print_report_name">'Maintenance Analysis - %s' % (context_today().strftime('%Y-%m-%d'))</field>
            <field name="binding_model_id" ref="model_fleet_maintenance_history_report"/>
            <field name="binding_type">report</field>
        </record>

        <record id="action_report_allocation_analysis" model="ir.actions.report">
            <field name="name">Vehicle Allocation Analysis</field>
            <field name="model">fleet.allocation.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hagbes_fleet.report_allocation_analysis</field>
            <field name="print_report_name">'Allocation Analysis - %s' % (context_today().strftime('%Y-%m-%d'))</field>
            <field name="binding_model_id" ref="model_fleet_allocation_report"/>
            <field name="binding_type">report</field>
        </record>

        <!-- Maintenance Due PDF Template -->
        <template id="report_maintenance_due">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="header">
                            <h2 class="text-center">Maintenance Due Analysis</h2>
                            <p class="text-center">Generated on <span t-esc="context_today().strftime('%d/%m/%Y')"/></p>
                        </div>

                        <table class="table table-sm table-bordered mt-4">
                            <thead style="background-color: #f5f5f5;">
                                <tr>
                                    <th>Vehicle</th>
                                    <th>Branch</th>
                                    <th>Current Odometer</th>
                                    <th>Last Service Date</th>
                                    <th>Days Since Service</th>
                                    <th>KM Since Service</th>
                                    <th>Due Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="docs" t-as="o">
                                    <tr>
                                        <td><span t-field="o.vehicle_id.name"/></td>
                                        <td><span t-field="o.company_id.name"/></td>
                                        <td class="text-end"><span t-field="o.current_odometer" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td><span t-field="o.last_service_date"/></td>
                                        <td class="text-end"><span t-field="o.days_since_service"/></td>
                                        <td class="text-end"><span t-field="o.km_since_service" t-options='{"widget": "float", "precision": 2}'/></td>
                                        <td><span t-field="o.due_status" widget="badge"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </template>

        <record id="action_report_maintenance_due_analysis" model="ir.actions.report">
            <field name="name">Maintenance Due Analysis</field>
            <field name="model">fleet.maintenance.due.report</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">hagbes_fleet.report_maintenance_due</field>
            <field name="print_report_name">'Maintenance Due - %s' % (context_today().strftime('%Y-%m-%d'))</field>
            <field name="binding_model_id" ref="model_fleet_maintenance_due_report"/>
            <field name="binding_type">report</field>
        </record>
    </data>
</odoo>
