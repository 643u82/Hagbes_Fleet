<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fleet_checkup_wizard_form" model="ir.ui.view">
        <field name="name">fleet.checkup.wizard.form</field>
        <field name="model">fleet.checkup.wizard</field>
        <field name="arch" type="xml">
            <form string="Daily Vehicle Checkup">
                <p class="alert alert-info">
                    Please update the status of all vehicles and drivers for today.
                </p>
                <field name="line_ids">
                    <list editable="bottom" create="0" delete="0">
                        <field name="vehicle_id"/>
                        <field name="current_driver_status"/>
                        <field name="current_vehicle_status"/>
                        <field name="notes"/>
                    </list>
                </field>
                <footer>
                    <button name="action_confirm" string="Submit Statuses" type="object" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_fleet_checkup_wizard" model="ir.actions.act_window">
        <field name="name">Daily Vehicle Checkup</field>
        <field name="res_model">fleet.checkup.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
