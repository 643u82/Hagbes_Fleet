<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Requisition Department Isolation -->
        <record id="rule_requisition_requester_dept" model="ir.rule">
            <field name="name">Requisition - Requester Department Only</field>
            <field name="model_id" ref="model_fleet_requisition"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fleet_requester'))]"/>
        </record>
        
        <record id="rule_requisition_dept_manager_dept" model="ir.rule">
            <field name="name">Requisition - Department Manager Department Only</field>
            <field name="model_id" ref="model_fleet_requisition"/>
            <field name="domain_force">[('department_id', '=', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_dept_manager'))]"/>
        </record>
        
        <!-- Trip Company Isolation -->
        <record id="rule_trip_company_isolation" model="ir.rule">
            <field name="name">Trip - Company Isolation</field>
            <field name="model_id" ref="model_fleet_trip"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo')), (4, ref('hagbes_fleet.group_fleet_requester'))]"/>
        </record>
        
        <!-- Driver Trip Assignment -->
        <record id="rule_trip_driver_assigned" model="ir.rule">
            <field name="name">Trip - Driver Assigned Only</field>
            <field name="model_id" ref="model_fleet_trip"/>
            <field name="domain_force">[('driver_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fleet_requester'))]"/>
        </record>
        
        <!-- Vehicle Company Isolation -->
        <record id="rule_vehicle_company_isolation" model="ir.rule">
            <field name="name">Vehicle - Company Isolation</field>
            <field name="model_id" ref="model_fleet_vehicle"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo')), (4, ref('hagbes_fleet.group_fleet_requester'))]"/>
        </record>
        
        <!-- Maintenance Vehicle Isolation -->
        <record id="rule_maintenance_vehicle_isolation" model="ir.rule">
            <field name="name">Maintenance - Vehicle Company Isolation</field>
            <field name="model_id" ref="model_fleet_maintenance"/>
            <field name="domain_force">[('vehicle_id.company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fleet_requester')), (4, ref('hagbes_fleet.group_fmo'))]"/>
        </record>
        
        <!-- Trip Log Isolation -->
        <record id="rule_trip_log_company_isolation" model="ir.rule">
            <field name="name">Trip Log - Company Isolation</field>
            <field name="model_id" ref="model_fleet_trip_log"/>
            <field name="domain_force">[('trip_id.company_id', 'in', user.company_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo'))]"/>
        </record>
        
    </data>
</odoo>
