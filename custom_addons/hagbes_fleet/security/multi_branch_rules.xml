<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Multi-Branch (Company) Isolation Rules -->
        <!-- These rules ensure users only see records for branches they are allowed to access -->

        <record model="ir.rule" id="hagbes_fleet_vehicle_comp_rule">
            <field name="name">Hagbes Fleet Vehicle Multi-Branch</field>
            <field name="model_id" ref="model_hagbes_fleet_vehicle"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.rule" id="fleet_requisition_comp_rule">
            <field name="name">Fleet Requisition Multi-Branch</field>
            <field name="model_id" ref="model_fleet_requisition"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.rule" id="hagbes_fleet_allocation_comp_rule">
            <field name="name">Fleet Allocation Multi-Branch</field>
            <field name="model_id" ref="model_hagbes_fleet_allocation"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.rule" id="fleet_trip_comp_rule">
            <field name="name">Fleet Trip Multi-Branch</field>
            <field name="model_id" ref="model_fleet_trip"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <record model="ir.rule" id="hagbes_fleet_maintenance_comp_rule">
            <field name="name">Fleet Maintenance Multi-Branch</field>
            <field name="model_id" ref="model_hagbes_fleet_maintenance"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
