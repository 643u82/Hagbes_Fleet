<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- FLEET VEHICLE RULES - hagbes.fleet.vehicle -->
        <record id="rule_fleet_vehicle_fmo" model="ir.rule">
            <field name="name">Fleet Vehicle - FMO Officer Full Access</field>
            <field name="model_id" ref="model_hagbes_fleet_vehicle"/>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo'))]"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
        </record>

        <record id="rule_fleet_vehicle_manager_read" model="ir.rule">
            <field name="name">Fleet Vehicle - Manager Read Only</field>
            <field name="model_id" ref="model_hagbes_fleet_vehicle"/>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_property_manager'))]"/>
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

        <!-- FLEET VEHICLE ASSIGNMENT RULES - hagbes.fleet.vehicle.assign -->
        <record id="rule_fleet_assign_fmo" model="ir.rule">
            <field name="name">Fleet Assignment - FMO Officer Full Access</field>
            <field name="model_id" ref="model_hagbes_fleet_vehicle_assign"/>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo'))]"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
        </record>

        <!-- FLEET MAINTENANCE RULES - hagbes.fleet.maintenance -->
        <record id="rule_fleet_maintenance_fmo" model="ir.rule">
            <field name="name">Fleet Maintenance - FMO Officer Full Access</field>
            <field name="model_id" ref="model_hagbes_fleet_maintenance"/>
            <field name="groups" eval="[(4, ref('hagbes_fleet.group_fmo'))]"/>
            <field name="domain_force">[('company_id', 'in', user.company_ids.ids)]</field>
        </record>

    </data>
</odoo>
