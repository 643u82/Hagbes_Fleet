<odoo>

    <!-- list View -->
    <record id="view_manual_document_list" model="ir.ui.view">
        <field name="name">manual.document.list</field>
        <field name="model">manual.document</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="uploaded_by"/>
                <field name="upload_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_manual_document_form" model="ir.ui.view">
        <field name="name">manual.document.form</field>
        <field name="model">manual.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="description"/>
                        <field name="file" filename="file_name"/>
                    </group>

                    <footer>
                        <button name="action_download"
                                type="object"
                                string="Download"
                                class="btn-primary"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_manual_document" model="ir.actions.act_window">
        <field name="name">User Manuals</field>
        <field name="res_model">manual.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_manual_root"
              name="Manual Management"
              sequence="10"/>

    <menuitem id="menu_manual_document"
              name="User Manuals"
              parent="menu_manual_root"
              action="action_manual_document"
              sequence="1"/>

</odoo>