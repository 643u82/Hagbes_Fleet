<odoo>
    <record id="hagbes_onduty_management_employee_approver_rule" model="ir.rule">
        <field name="name">OnDuty approvers see others forms</field>
        <field name="model_id" ref="model_onduty_report"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hagbes_timeoff_management.group_timeoff_approver'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="hagbes_onduty_management_report_view_rule" model="ir.rule">
        <field name="name">OnDuty Report branch only</field>
        <field name="model_id" ref="model_onduty_report"/>
        <field name="domain_force">[('company_id','in',user.company_ids.ids), ('branch_id', 'in', user.allowed_branch_ids.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
</odoo>
