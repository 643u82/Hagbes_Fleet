<odoo>
    <record id="view_onduty_list_readonly" model="ir.ui.view">
        <field name="name">onduty.report.list.readonly</field>
        <field name="model">onduty.report</field>
        <field name="arch" type="xml">
            <list string="On-Duty Reports" create="false" edit="false" delete="false">
                <field name="employee_id" options="{'no_open': True}"/>
                <field name="department_id" options="{'no_open': True}"/>
                <field name="company_id" options="{'no_open': True}"/>
                <field name="branch_company"/>
                <field name="sister_company"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_onduty_form_readonly" model="ir.ui.view">
        <field name="name">onduty.report.form.readonly</field>
        <field name="model">onduty.report</field>
        <field name="arch" type="xml">
            <form string="On-Duty Report" create="false" edit="false" delete="false">
                <sheet>
                    <group string="Employee Info">
                        <field name="employee_id" readonly="1" options="{'no_open': True}"/>
                        <field name="department_id" readonly="1" options="{'no_open': True}"/>
                        <field name="company_id" readonly="1" options="{'no_open': True}"/>
                        <field name="job_id" readonly="1" options="{'no_open': True}"/>
                        <field name="branch_id" readonly="1" options="{'no_open': True}"/>
                    </group>
                    <group string="Duty Info">
                        <field name="branch_company" readonly="1" options="{'no_open': True}"/>
                        <field name="sister_company" readonly="1" options="{'no_open': True}"/>
                        <field name="other_company" readonly="1"/>
                        <field name="start_date" readonly="1"/>
                        <field name="end_date" readonly="1"/>
                        <field name="duty" readonly="1"/>
                        <field name="remark" readonly="1"/>
                        <field name="attachment" readonly="1"/>
                    </group>
                    <group string="Status">
                        <field name="state" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>