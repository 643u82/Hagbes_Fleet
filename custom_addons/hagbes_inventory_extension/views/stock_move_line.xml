<odoo>
    <record id="view_stock_move_line_tree_inherit_balance" model="ir.ui.view">
        <field name="name">stock.move.line.tree.balance</field>
        <field name="model">stock.move.line</field>
        <field name="inherit_id" ref="stock.view_move_line_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='quantity']" position="replace">
                <field name="display_quantity"
                       string="Balance"
                       decoration-danger="(location_usage in ('internal','transit')) and (location_dest_usage not in ('internal','transit'))"
                       decoration-success="(location_usage not in ('internal','transit')) and (location_dest_usage in ('internal','transit'))"/>
            </xpath>
            <xpath expr="//field[@name='display_quantity']" position="before">
                <field name="move_type"
                       string="Moves Type"
                       decoration-danger="(location_usage in ('internal','transit')) and (location_dest_usage not in ('internal','transit'))"
                       decoration-success="(location_usage not in ('internal','transit')) and (location_dest_usage in ('internal','transit'))"/>
            </xpath>
        </field>
    </record>
    <record id="stock_move_line_view_search_custom" model="ir.ui.view">
    <field name="name">stock.move.line.search.custom</field>
    <field name="model">stock.move.line</field>
    <field name="inherit_id" ref="stock.stock_move_line_view_search"/>
    <field name="arch" type="xml">
        <xpath expr="//filter[@name='by_location']" position="replace"/>
        <xpath expr="//group[@name='groupby']" position="inside">
            <filter string="By Location" name="group_by_any_location"
                    context="{'group_by': 'location_group_ids'}"/>
        </xpath>
    </field>
</record>



</odoo>
