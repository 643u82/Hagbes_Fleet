<odoo>
    <record id="view_stock_move_tree_custom_receipt" model="ir.ui.view">
        <field name="name">stock.move.tree.custom.receipt</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_tree"/>
        <field name="arch" type="xml">

            <!-- Rename 'Demand' to 'Requested' -->
            <xpath expr="//field[@name='product_uom_qty']" position="attributes">
                <attribute name="string">Requested</attribute>
            </xpath>

            <!-- Rename 'Quantity' to 'Received' -->
            <xpath expr="//field[@name='quantity']" position="attributes">
                <attribute name="string">Received</attribute>
            </xpath>

            <!-- Add 'Remark' field after 'quantity_done' -->
            <xpath expr="//field[@name='quantity']" position="after">
                <field name="remark"/>
            </xpath>

        </field>
    </record>
</odoo>
