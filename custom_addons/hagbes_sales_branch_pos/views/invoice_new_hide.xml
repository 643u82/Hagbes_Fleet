<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Prevent manual invoice creation — enforce via Sales Orders -->
    <record id="view_account_move_tree_inherit_no_create" model="ir.ui.view">
        <field name="name">account.move.tree.inherit.no.create</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_move_tree"/>
        <field name="arch" type="xml">
            <!-- 🚫 Hides the "New" button in list view -->
            <xpath expr="//tree" position="attributes">
                <attribute name="create">0</attribute>
            </xpath>
        </field>
    </record>
</odoo>