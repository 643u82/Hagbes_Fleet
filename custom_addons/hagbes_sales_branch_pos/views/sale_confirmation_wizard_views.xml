<odoo>
  <record id="view_sale_confirmation_wizard" model="ir.ui.view">
    <field name="name">sale.confirmation.wizard.form</field>
    <field name="model">sale.confirmation.wizard</field>
    <field name="arch" type="xml">
      <form string="Insufficient Stock Confirmation">
        <group>
          <field name="sale_order_id" readonly="1"/>

          <!-- 🔧 Correctly defining the One2many relation and its inline tree -->
          <field name="line_ids">
            <list>
              <field name="product_id"/>
              <field name="requested"/>
              <field name="available"/>
              <field name="shortage"/>
            </list>
          </field>
        </group>

        <footer>
          <button string="Confirm with Available" type="object" name="confirm_partial" class="btn-primary"/>
          <button string="Mark as Lost" type="object" name="mark_as_lost" class="btn-danger"/>
          <button string="Cancel" special="cancel" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_sale_confirmation_wizard" model="ir.actions.act_window">
    <field name="name">Stock Confirmation</field>
    <field name="res_model">sale.confirmation.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>
</odoo>
