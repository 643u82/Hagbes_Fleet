<?xml version="1.0" encoding="utf-8"?>
<odoo>


    <record id="sale.sale_order_see_all" model="ir.rule">
        <field name="name">Sales Orders: All Documents (Allowed Branches Only)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman_all_leads'))]"/>
        <field name="domain_force">
            [('branch_id', 'in', user.allowed_branch_ids.ids)]
        </field>
    </record>


    <record id="sale_order_branch_own_rule" model="ir.rule">
        <field name="name">Sales Orders: Own Documents (Allowed Branches)</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
        <field name="domain_force">
            [
                '&amp;',
                ('user_id', '=', user.id),
                ('branch_id', 'in', user.allowed_branch_ids.ids)
            ]
        </field>
    </record>




</odoo>