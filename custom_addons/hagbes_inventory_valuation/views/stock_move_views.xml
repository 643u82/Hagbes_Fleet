<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_inherit_stock_valuation" model="ir.ui.view">
        <field name="name">stock.move.form.inherit.stock.valuation</field>
        <field name="model">stock.move</field>
        <field name="inherit_id" ref="stock.view_move_form"/>
        <field name="arch" type="xml">
            
            <group name="origin_grp" position="after">
                <group name="accounting_info" string="Accounting Information" 
                       groups="account.group_account_user"
                       invisible="product_id.categ_id.property_valuation == 'manual_periodic'">
                    <field name="product_id" invisible="1"/>
                    <label for="product_id" string="Valuation Method"/>
                    <div>
                        <field name="product_id" readonly="1" nolabel="1" 
                               context="{'show_valuation': True}"/>
                    </div>
                </group>
            </group>
            
        </field>
    </record>
</odoo>
