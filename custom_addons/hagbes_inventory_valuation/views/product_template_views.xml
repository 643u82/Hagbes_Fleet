<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_stock_valuation" model="ir.ui.view">
        <field name="name">product.template.form.inherit.stock.valuation</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            
            <page name="inventory" position="inside">
                <group name="stock_valuation_info" string="Stock Valuation" col="2">
                    <field name="valuation" readonly="1"/>
                    <field name="stock_valuation_account_id" readonly="1" 
                           invisible="valuation == 'manual_periodic'"/>
                </group>
            </page>
            
        </field>
    </record>
</odoo>
