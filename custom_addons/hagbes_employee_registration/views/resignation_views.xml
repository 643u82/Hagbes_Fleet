<odoo>

    <!-- Resignation Form View -->
    <record id="view_employee_resignation_form" model="ir.ui.view">
        <field name="name">employee.resignation.form</field>
        <field name="model">employee.resignation</field>
        <field name="arch" type="xml">
            <form string="Resignation Request">
                 <header>
                        <button name="action_submit" type="object" string="Submit"
                                 class="btn btn-primary"
                                  invisible="state != 'draft'"
                                />

                       <button name="action_open_remark_wizard_approve"
                                type="object"
                                string="Approve"
                                class="btn btn-success"
                                invisible="state != 'pending' or can_approve == False"/>

                        
       

                        <button name="action_open_remark_wizard_reject" type="object" string="Reject"
                                class="btn btn-danger"
                                 invisible="state != 'pending' or can_approve == False"
                               />
                        <button name="action_open_remark_wizard_agreement_reached"
                                type="object"
                                string="Agreement Reached"
                                class="btn btn-info"
                                invisible="state != 'pending' or can_approve == False"/>

                                            <field name="state" readonly="1"/>

                    </header>
                <sheet>
                     
                        <div style="margin-top: 4px;">
                           <field name="name"
                           readonly="1"
                           style="font-size: 30px; display: block;"
                           modifiers="{'invisible': [['name', '=', false]]}" />
                        </div>
                    
                    <group>
                        <field name="employee_id" readonly="1"/>
                        <field name="department_id"/>
                        <field name="job_id"/>
                        <field name="resignation_date"/>
                    </group>
                    <group>
                        <field name="reason" />
                        <field name="other_reason"
                               modifiers='{"invisible": [["show_other_reason", "=", false]],
                                           "required": [["reason", "=", "other"]]}'
                                        placeholder="Please specify your reason here"/>
                    </group>
                    <group>
                        <field name="state" readonly="1"/>
                        <field name="step_progress" widget="html" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Remarks History">
                            <field name="remark_ids" nolabel="1">
                                <list>
                                    <field name="date" readonly="1" options="{'no_create': True}"/>
                                    <field name="user_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="job_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="action_type" readonly="1" options="{'no_create': True}"/>
                                    <field name="comment" readonly="1" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
               
            </form>
        </field>
    </record>

    <!-- Optional: Tree view -->
    <record id="view_employee_resignation_list" model="ir.ui.view">
        <field name="name">employee.resignation.list</field>
        <field name="model">employee.resignation</field>
        <field name="arch" type="xml">
            <list string="Resignation Requests">
                <field name="employee_id" readonly="1"/>
                <field name="department_id"/>
                <field name="resignation_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>
     <!-- DOMIN -->
     
    <record id="employee_resignation_rule_user" model="ir.rule">
        <field name="name">Employee Resignation: Own records</field>
        <field name="model_id" ref="hagbes_employee_registration.model_employee_resignation"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
    </record>
    <!-- Action to open the form -->
    <record id="action_employee_resignation" model="ir.actions.act_window">
        <field name="name">Resignation</field>
        <field name="res_model">employee.resignation</field>
        <field name="view_mode">list,form</field>
    </record>

    <!--Accptance letters form view-->
    
    
    <record id="view_acceptance_letter_form" model="ir.ui.view">
        <field name="name">acceptance.letter.form</field>
        <field name="model">employee.resignation.acceptance</field>
        <field name="arch" type="xml">
            <form string="Acceptance Letter">
                <header>
                    <button name="action_submit" type="object" string="Submit"
                                class="btn btn-primary"
                                invisible="state != 'draft'"
                            />

                    <button name="action_approve" type="object" string="Approve"
                            class="btn btn-success"
                            invisible="state != 'pending'"
                            />

                    <button name="action_reject" type="object" string="Reject"
                            class="btn btn-danger"
                                invisible="state != 'rejected'"
                            />
                    <field name="state" readonly="1"/>
                    <button name="action_load_cc_users"
                            type="object"
                            string="Load CC"
                            class="btn-secondary"/>
                    <button name="action_to_terminate"
                            type="object"
                            string="To Terminate"
                            class="btn-warning"
                            />
                </header>
                 <sheet readonly="state in ('approved','rejected','pending')">
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="req_type">
                            <attribute name="options">{'no_create': True}</attribute>
                            <attribute name="placeholder">Select Type</attribute> 
                        </field>
                        <field name="ref"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="acceptance_date"/>
                        <field name="comments"/>
                        <field name="cc_user_ids" widget="many2many_tags" options="{'no_create': True}" placeholder="CC"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="view_acceptance_letter_list" model="ir.ui.view">
        <field name="name">acceptance.letter.list</field>
        <field name="model">employee.resignation.acceptance</field>
        <field name="arch" type="xml">
            <list string="Acceptance Letters">
                <field name="name"/>
                <field name="req_type"/>
                <field name="ref"/>
                <field name="employee_id"/>
                <field name="acceptance_date"/>
            </list>
        </field>
    </record>
    <!-- Action to open the form -->
    <record id="action_employee_acceptance_letters" model="ir.actions.act_window">
        <field name="name">acceptance</field>
        <field name="res_model">employee.resignation.acceptance</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--discipline-->
    <record id="view_employee_discipline_form" model="ir.ui.view">
        <field name="name">employee.discipline.form</field>
        <field name="model">employee.discipline</field>
        <field name="arch" type="xml">
            <form string="Employee Discipline">
                    <header>
                       
                        <button name="action_submit" type="object" string="Submit"
                                class="btn btn-primary"
                                invisible="state != 'draft'"/>

        
                        <button name="action_open_remark_wizard_pass_legal"
                                type="object"
                                string="Send to Legal"
                                class="btn btn-warning"
                                invisible="state != 'pending' or can_approve == False"
                                groups="hagbes_employee_registration.group_legal_action"/>
                                

                        <button name="action_open_remark_wizard_approve"
                                type="object"
                                string="Approve"
                                class="btn btn-success"
                                invisible="state != 'pending' or can_approve == False"/>

                        <button name ="action_open_remark_wizard_forward"
                                type="object"
                                string="Forward"
                                class="btn btn-info"
                                invisible="state != 'pending' or can_approve == False"
                                groups="hagbes_employee_registration.group_forward_action"/>
                            
                        

                        <button name="action_open_remark_wizard_reject" type="object" string="Reject"
                                class="btn btn-danger"
                                invisible="state != 'pending' or can_approve == False"/>

                                            <field name="state" readonly="1"/>

                    </header>
                 <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="company_id" options="{'no_create': True, 'no_open': True}" readonly="1" />
                        <field name="branch_id"  options="{'no_create': True, 'no_open': True}"/>
                        <field name="department_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="job_id"  options="{'no_create': True, 'no_open': True}"/>
                        <field name="employee_id"  options="{'no_create': True, 'no_open': True}"/>
                        <field name="action_type" groups="hagbes_employee_registration.group_hr_discipline"/>
                        <field name="date"/>
                        <field name="description"/>
                    </group>
                    <group string="Process Info">
                        <field name="state" readonly="1"/>
                        <field name="step_progress" widget="html" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Remarks History">
                            <field name="remark_ids" nolabel="1">
                                <list>
                                    <field name="date" readonly="1" options="{'no_create': True}"/>
                                    <field name="user_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="job_id" readonly="1" options="{'no_create': True}"/>
                                    <field name="action_type" readonly="1" options="{'no_create': True}"/>
                                    <field name="comment" readonly="1" options="{'no_create': True}"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>
            </form>
        </field>
    </record>
    <record id="view_employee_discipline_list" model="ir.ui.view">
        <field name="name">employee.discipline.list</field>
        <field name="model">employee.discipline</field>
        <field name="arch" type="xml">
            <list string="Employee Discipline">
                <field name="employee_id"/>
                <field name="action_type"/>
                <field name="date"/>
                <field name="reason"/>
            </list>
        </field>
    </record>
    <!-- Action to open the form -->
    <record id="action_employee_discipline" model="ir.actions.act_window">
        <field name="name">Discipline</field>
        <field name="res_model">employee.discipline</field>
        <field name="view_mode">list,form</field>
    </record>
    <!--retirmenent-->
    <record id="view_employee_retirement_form" model="ir.ui.view">
        <field name="name">employee.retirement.form</field>
        <field name="model">employee.retirement</field>
        <field name="arch" type="xml">
            <form string="Retirement">
                <sheet>
                    <!-- <header>
                        <button name="action_submit" type="object" string="Submit"
                                 class="btn btn-primary"
                                  invisible="state != 'draft'"
                                />

                        <button name="action_approve" type="object" string="Approve"
                                class="btn btn-success"
                                invisible="state != 'pending'"
                               />

                        <button name="action_reject" type="object" string="Reject"
                                class="btn btn-danger"
                                 invisible="state != 'rejected'"
                               />
                                            <field name="state" readonly="1"/>

                    </header> -->
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="employee_id" readonly="1"/>
                        <field name="branch_id" readonly="1"/>
                        <field name="department_id" readonly="1"/>
                        <field name="retirement_date"/>
                        <field name="reason"/>
                        <field name="state" readonly="1"/>
                    </group>
                        <!-- <div class="oe_chatter" style="width: 400px; float: right;">
                            <field name="message_follower_ids"/>
                            <field name="message_ids" widget="mail_thread"/>
                        </div> -->
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_retirement_list" model="ir.ui.view">
        <field name="name">employee.retirement.list</field>
        <field name="model">employee.retirement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="retirement_date"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_employee_retirement" model="ir.actions.act_window">
        <field name="name">Retirement Records</field>
        <field name="res_model">employee.retirement</field>
        <field name="view_mode">list,form</field>
       

    </record>
    <!--termination-->
    <record id="view_employee_termination_form" model="ir.ui.view">
        <field name="name">employee.termination.form</field>
        <field name="model">employee.termination</field>
        <field name="arch" type="xml">
            <form string="Employee Termination">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="employee_id"/>
                        <field name="termination_date"/>
                        <field name="termination_type"/>
                        <field name="reason"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_employee_termination_list" model="ir.ui.view">
        <field name="name">employee.termination.list</field>
        <field name="model">employee.termination</field>
        <field name="arch" type="xml">
            <list string="Employee Terminations">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="termination_date"/>
                <field name="termination_type"/>
            </list>
        </field>
    </record>

    <record id="action_employee_termination" model="ir.actions.act_window">
        <field name="name">Terminations</field>
        <field name="res_model">employee.termination</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Add to HR menu -->
    <menuitem id="menu_hr_resignation_root" name="Termination" parent="hr.menu_hr_root"/>
    <menuitem id="menu_hr_resignation" name="Resignation Requests" parent="menu_hr_resignation_root" action="action_employee_resignation" sequence="1"/>
    <menuitem id="acceptance_menu" name="Acceptance Letters" parent="menu_hr_resignation_root" action="action_employee_acceptance_letters" sequence="2" />
    <menuitem id="disiplinary_menu" name="Disciplin" parent="menu_hr_resignation_root" action= "action_employee_discipline" sequence="3"/>
    <menuitem id="termination_menu" name="Termination" parent="menu_hr_resignation_root" action= "action_employee_termination" sequence="5"/>
    <menuitem id="retirement_menu" name="Retirement" parent="menu_hr_resignation_root" 
              action="action_employee_retirement" sequence="4"  />
</odoo>
