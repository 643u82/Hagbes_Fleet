<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_emp_id" model="ir.ui.view">
        <field name="name">hr.employee.form.emp_id</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <!-- Add emp_id below the name field, as a new row -->
            <field name="name" position="before">
                <div style="margin-top: 4px;">
                    <field name="emp_id"
                           readonly="1"
                           style="font-size: 30px; display: block;"
                           modifiers="{'invisible': [['emp_id', '=', false]]}" />
                </div>
            </field>
        </field>
    </record>
</odoo>
