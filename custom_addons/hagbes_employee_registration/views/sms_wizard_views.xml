<odoo>
    <record id="view_sms_wizard_form" model="ir.ui.view">
        <field name="name">sms.wizard.form</field>
        <field name="model">sms.wizard</field>
        <field name="arch" type="xml">
            <form string="Send SMS / Reset Password">
                <sheet>
                    <group>
                        <field name="employee_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="reset_password"/>
                        <field name="reset_all_passwords" readonly="1"/>
                        <field name="send_sms"/>
                        <field name="send_to_all" readonly= "1"/>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                    <footer>
                        <button string="Send" type="object" name="action_send_sms"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
    <!-- inheriting the main sms form in hr.employee  -->
    <record id="inherit_sms_composer_view_form" model="ir.ui.view">
        <field name="name">sms.sms.composer.view.form.inherit</field>
        <field name="model">sms.composer</field>
        <field name="inherit_id" ref="sms.sms_composer_view_form" />
        <field name="arch" type="xml">
            <!-- Example: Add field after 'message' -->
            <xpath expr="//field[@name='body']" position="after">
                <field name="reset_password"/>
            </xpath>
            <xpath expr="//field[@name='body']" position="after">
                <field name="employee_ids" widget="many2many_tags" readonly="1"/>
            </xpath>
            <xpath expr="//button[@name='action_send_sms']" position="replace">
                <button name="button_load_and_send_sms"
                        type="object"
                        string="Send SMS"
                        class="btn-primary"/>

            </xpath>
           
        </field>
    </record>




    <!-- Action to open wizard -->
    <record id="action_sms_wizard" model="ir.actions.act_window">
        <field name="name">Send SMS / Reset Password</field>
        <field name="res_model">sms.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu item under Settings -->
<!-- Menu under Settings -->
    <menuitem id="menu_sms_wizard_root"
              name="SMS and Password"
              parent="base.menu_administration"
              sequence="100"/>

   <!-- Duplicate menu under hr.menu_hr_root pointing to same action -->
   
   <menuitem id="menu_sms_wizard_hr"
            name="SMS and Password"
            parent="hr.menu_hr_main"
            action="action_sms_wizard"
            sequence="100"
            groups="hr.group_hr_user,base.group_system"
           />

    <!-- Add menu action -->
    <menuitem id="menu_sms_wizard_action"
              name="Send SMS / Reset Password"
              parent="menu_sms_wizard_root"
              action="action_sms_wizard"
              sequence="10"/>

   
            
</odoo>
