<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_employee_retirement_processing" model="ir.cron">
        <field name="name">Process Employee Retirements</field>
        <field name="model_id" ref="model_employee_retirement"/>
        <field name="state">code</field>
        <field name="code">model.move_to_retirement()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
        <field name="user_id" ref="base.user_root"/>
    </record>
    <record id="ir_cron_retirement_notification" model="ir.cron">
        <field name="name">Check 3-Month Retirement Notifications</field>
        <field name="model_id" ref="model_employee_retirement"/>
        <field name="state">code</field>
        <field name="code">model.cron_check_retirement_notifications()</field>
        <field name="active">True</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>
    <record id="ir_cron_clear_all_retirements" model="ir.cron">
            <field name="name">Clear All Employee Retirement Records</field>
            <field name="model_id" ref="model_employee_retirement"/> 
            <field name="code">model.clear_all_retirements()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field> 
     </record>
</odoo>