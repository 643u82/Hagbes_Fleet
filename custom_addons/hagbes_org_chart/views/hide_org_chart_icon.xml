<odoo>
   <record id="hr_employee_view_form_inherit_org_chart" model="ir.ui.view">
     <field name="name">hr.employee.view.form.inherit.org_chart.hide.button</field>
     <field name="model">hr.employee</field>
     <field name="inherit_id" ref="hr.view_employee_form"/>
     <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']/button[@icon='fa-users']" position="attributes">
            <attribute name="invisible">1</attribute>
        </xpath>
     </field>
   </record>

</odoo>


