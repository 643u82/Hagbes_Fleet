<odoo>
    <record id="user_manual_rule" model="ir.rule">
        <field name="name">User Manual Access</field>
        <field name="model_id" ref="model_user_manual_category"/>
        <field name="groups" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="domain_force">
            [
                '|',
                ('group_id', 'in', user.groups_id.ids),
                user.has_group('base.group_system') or user.has_group('hr.group_hr_manager')
            ]
        </field>
    </record>
</odoo>
