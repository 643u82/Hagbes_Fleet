<odoo>
    <!-- Reconciler Rule: Only see own headers -->
    <record id="bank_reco_rule_reconciler_own_header" model="ir.rule">
        <field name="name">Reconciler: Own Reconciliations (Header)</field>
        <field name="model_id" ref="model_bank_reco_header"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hagbes_bank_reconciliation.group_bank_reco_reconciler'))]"/>
    </record>

    <!-- Manager Rule: See all headers -->
    <record id="bank_reco_rule_manager_all_header" model="ir.rule">
        <field name="name">Manager: All Reconciliations (Header)</field>
        <field name="model_id" ref="model_bank_reco_header"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hagbes_bank_reconciliation.group_bank_reco_manager'))]"/>
    </record>

    <!-- Reconciler Rule: Only see matched detail lines -->
    <record id="bank_reco_rule_reconciler_own_detail" model="ir.rule">
        <field name="name">Reconciler: Matched Details (Detail)</field>
        <field name="model_id" ref="model_bank_reco_detail"/>
        <field name="domain_force">['|', ('matched_by', '=', user.id), ('matched_by', '=', False)]</field>
        <field name="groups" eval="[(4, ref('hagbes_bank_reconciliation.group_bank_reco_reconciler'))]"/>
    </record>

    <!-- Manager Rule: See all details -->
    <record id="bank_reco_rule_manager_all_detail" model="ir.rule">
        <field name="name">Manager: All Reconciliations (Detail)</field>
        <field name="model_id" ref="model_bank_reco_detail"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hagbes_bank_reconciliation.group_bank_reco_manager'))]"/>
    </record>
</odoo>
