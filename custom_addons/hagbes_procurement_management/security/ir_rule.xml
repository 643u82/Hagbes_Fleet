<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="purchase_order_comp_rule" model="ir.rule">
            <field name="name">Purchase Order multi-company rule</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="purchase_order_line_comp_rule" model="ir.rule">
            <field name="name">Purchase Order Line multi-company rule</field>
            <field name="model_id" ref="purchase.model_purchase_order_line"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="purchase_request_comp_rule" model="ir.rule">
            <field name="name">Purchase Request multi-company rule</field>
            <field name="model_id" ref="model_purchase_request"/>
            <field name="global" eval="True"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Branch Access Rules for Purchase Request -->
        <record id="purchase_request_branch_rule_user" model="ir.rule">
            <field name="name">Purchase Request Branch Rule (User)</field>
            <field name="model_id" ref="model_purchase_request"/>
            <!-- Show PRs where branch is not set, or branch is in user's allowed branches -->
            <field name="domain_force">['|', ('branch_id', '=', False), ('branch_id', 'in', user.allowed_branch_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_procurement_management.group_foreign_procurement_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="purchase_request_all_rule_officer" model="ir.rule">
            <field name="name">Purchase Request All Access (Officer+)</field>
            <field name="model_id" ref="model_purchase_request"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hagbes_procurement_management.group_foreign_procurement_officer')), (4, ref('hagbes_procurement_management.group_foreign_procurement_manager')), (4, ref('hagbes_procurement_management.group_foreign_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Branch Access Rules for Purchase Order -->
        <record id="purchase_order_branch_rule_user" model="ir.rule">
            <field name="name">Purchase Order Branch Rule (User)</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="domain_force">['|', ('branch_id', '=', False), ('branch_id', 'in', user.allowed_branch_ids.ids)]</field>
            <field name="groups" eval="[(4, ref('hagbes_procurement_management.group_foreign_procurement_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="purchase_order_all_rule_officer" model="ir.rule">
            <field name="name">Purchase Order All Access (Officer+)</field>
            <field name="model_id" ref="purchase.model_purchase_order"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('hagbes_procurement_management.group_foreign_procurement_officer')), (4, ref('hagbes_procurement_management.group_foreign_procurement_manager')), (4, ref('hagbes_procurement_management.group_foreign_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>