<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Hide default Purchase menus -->
        <record id="purchase.menu_procurement_management" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>

      
        <record id="purchase.menu_purchase_root" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('purchase.group_purchase_user')])]"/>
        </record>

        <record id="purchase.menu_purchase_rfq" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>
        <record id="purchase.menu_purchase_form_action" model="ir.ui.menu">
            <field name="groups_id" eval="[(6, 0, [ref('base.group_no_one')])]"/>
        </record>
        
        <record id="purchase.menu_purchase_products" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

      
        <record id="purchase.menu_purchase_config" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <!-- FOREIGN PROCUREMENT SECTION -->
        <menuitem id="menu_foreign_procurement_root"
                  name="Foreign Procurement"
                  parent="purchase.menu_purchase_root"
                  sequence="50"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <!-- Restrict entire procurement subtree by applying the group on this section -->
        <menuitem id="menu_procurement_section"
                  name="Procurement"
                  parent="menu_foreign_procurement_root"
                  sequence="5"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_purchase_requests"
                  name="Purchase Requests"
                  parent="menu_procurement_section"
                  action="action_purchase_request"
                  sequence="5"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_manual_inventory"
                  name="Manual Inventory Entry"
                  parent="purchase.menu_purchase_root"
                  action="action_manual_inventory_entry"
                  sequence="10"
                  groups="hagbes_procurement_management.group_manual_inventory_user"/>


        <record id="action_foreign_purchase_orders" model="ir.actions.act_window">
            <field name="name">Foreign Purchase Orders</field>
            <field name="res_model">purchase.order</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('order_type', '=', 'foreign')]</field>
            <field name="context">{ 'default_order_type': 'foreign', 'search_default_approved': 1 }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first foreign purchase order!
                </p>
                <p>
                    Purchase orders for foreign suppliers with special procurement processes.
                </p>
            </field>
            <field name="groups_id" eval="[(6,0,[ref('hagbes_procurement_management.group_foreign_procurement_user')])]"/>
        </record>

        <menuitem id="menu_foreign_purchase_orders"
                  name="Purchase Orders"
                  parent="menu_procurement_section"
                  action="action_foreign_purchase_orders"
                  sequence="20"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_payment_requests"
                  name="Payment Requests"
                  parent="menu_foreign_procurement_root"
                  sequence="15"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_payment_request_all"
                  name=" Requests"
                  parent="menu_foreign_payment_requests"
                  action="action_foreign_payment_request"
                  sequence="10"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_bank_process"
                  name="Bank Follow-up"
                  parent="menu_foreign_procurement_root"
                  sequence="10"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_bank_process_all"
                  name="Bank Processes"
                  parent="menu_foreign_bank_process"
                  action="action_foreign_bank_process"
                  sequence="10"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <!-- <menuitem id="menu_foreign_shipment"
                  name="Shipment Tracking"
                  parent="menu_foreign_procurement_root"
