                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_shipment_all"
                  name="Shipments"
                  parent="menu_foreign_shipment"
                  action="hagbes_procurement_management.action_foreign_shipment"
