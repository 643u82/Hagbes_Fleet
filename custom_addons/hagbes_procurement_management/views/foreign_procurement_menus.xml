        <menuitem id="menu_foreign_landing"
                  name="Landing Process"
                  parent="menu_foreign_procurement_root"
                  sequence="40"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <menuitem id="menu_foreign_costing"
                  name="Costing &amp; Landed Costs"
                  parent="menu_foreign_landing"
                  action="action_foreign_costing"
                  sequence="27"
                  groups="hagbes_procurement_management.group_foreign_procurement_user"/>

        <!-- Transit Management -->
        <menuitem id="menu_transit_management_section"
                  name="Transit Management"
                  parent="menu_foreign_procurement_root"
                  sequence="15"
                  groups="hagbes_procurement_management.group_foreign_procurement_transit"/>

        <menuitem id="menu_transit_management"
                  name="Transit Processes"
                  parent="menu_transit_management_section"
                  action="action_foreign_transit_process"
                  sequence="10"
                  groups="hagbes_procurement_management.group_foreign_procurement_transit"/>

        <!-- The LOCAL PROCUREMENT SECTION was removed from this file to avoid conflicts. Its definitions are in local_procurement_menus.xml -->
        <menuitem id="menu_unified_vendors_root"
                  name="Vendors"
                  parent="purchase.menu_purchase_root"
                  sequence="65"
                  groups="purchase.group_purchase_user"/>

        <!-- Vendor Management Submenus -->
        <menuitem id="menu_all_vendors"
                  name="All Vendors"
                  parent="menu_unified_vendors_root"
                  action="base.action_partner_supplier_form"
                  sequence="10"/>

        <menuitem id="menu_foreign_vendors"
                  name="Foreign Vendors"
                  parent="menu_unified_vendors_root"
                  sequence="20"/>

        <menuitem id="menu_local_vendors_list"
                  name="Local Vendors"
                  parent="menu_unified_vendors_root"
                  sequence="30"/>

        <menuitem id="menu_vendor_categories_unified"
                  name="Vendor Categories"
                  parent="menu_unified_vendors_root"
                  action="base.action_partner_category_form"
                  sequence="40"/>

        <menuitem id="menu_vendor_evaluation_unified"
                  name="Vendor Evaluation"
                  parent="menu_unified_vendors_root"
                  sequence="50"/>

