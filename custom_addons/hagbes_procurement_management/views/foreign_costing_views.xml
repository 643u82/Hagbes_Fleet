<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_foreign_costing_tree" model="ir.ui.view">
        <field name="name">foreign.costing.tree</field>
        <field name="model">foreign.costing</field>
        <field name="arch" type="xml">
            <list string="Foreign Costings"
                  decoration-info="state=='draft'"
                  decoration-warning="state=='confirmed'"
                  decoration-success="state=='done'"
                  decoration-muted="state=='cancelled'">
                <field name="reference"/>
                <field name="date"/>
                <field name="purchase_order_id"/>
                <field name="total_products"/>
                <field name="total_landed_cost_fx" widget="monetary" string="Grand Total (Birr)"/>
                <field name="cost_rate_fx"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_foreign_costing_form" model="ir.ui.view">
        <field name="name">foreign.costing.form</field>
        <field name="model">foreign.costing</field>
        <field name="arch" type="xml">
            <form string="Foreign Costing">
                <header>
                    <button name="action_calculate_costing" string="Calculate Costing"
                            type="object" class="oe_highlight" invisible="state != 'draft'"
                            groups="hagbes_procurement_management.group_foreign_procurement_costing" />

                    <button name="action_submit_for_approval" string="Submit for Approval"
                            type="object" class="oe_highlight" invisible="state != 'calculated'"
                            groups="hagbes_procurement_management.group_foreign_procurement_costing" />

                    <button name="action_manager_approve" string="Approve (Procurement  Manager)"
                            type="object" class="btn-primary"
                            invisible="not (state == 'waiting_for_manager' and is_current_user_approver)" />

                    <button name="action_gm_approve" string="Approve (General Manager)"
                            type="object" class="btn-primary"
                            invisible="not (state == 'waiting_for_gm' and is_current_user_approver)" />

                    <button name="action_director_approve" string="Approve (Director)"
                            type="object" class="btn-primary"
                            invisible="not (state == 'waiting_for_director' and is_current_user_approver)" />

                    <button name="action_finance_confirm" string="Confirm (Finance Manager)"
                            type="object" class="btn-success"
                            invisible="not (state == 'waiting_for_finance' and is_current_user_approver)" />

                    <button name="action_confirm" string="Confirm"
                            type="object" class="oe_highlight"
                            invisible="state != 'approved'"
                            groups="hagbes_procurement_management.group_foreign_procurement_manager" />
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state not in ['draft', 'calculated', 'waiting_for_manager', 'waiting_for_gm', 'waiting_for_director', 'waiting_for_finance', 'approved', 'confirmed']"
                            groups="hagbes_procurement_management.group_foreign_procurement_costing,hagbes_procurement_management.group_foreign_procurement_manager,hagbes_procurement_management.group_foreign_procurement_admin" />
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ['cancelled', 'rejected', 'waiting_for_manager', 'waiting_for_gm', 'waiting_for_director', 'approved']"
                            groups="hagbes_procurement_management.group_foreign_procurement_manager,hagbes_procurement_management.group_foreign_procurement_admin" />
                    

                    <!-- <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            if="record.state.raw_value == 'rejected'"
                            groups="hagbes_procurement_management.group_foreign_procurement_manager,hagbes_procurement_management.group_foreign_procurement_admin"/> -->


                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="not (state in ['waiting_for_manager', 'waiting_for_gm', 'waiting_for_director'] and is_current_user_approver)"
                            groups="hagbes_procurement_management.group_foreign_procurement_user,hagbes_procurement_management.group_foreign_procurement_manager,hagbes_procurement_management.group_foreign_procurement_admin" />

                    <field name="state" widget="statusbar"
                            statusbar_visible="draft,calculated,waiting_for_manager,waiting_for_gm,waiting_for_director,waiting_for_finance,waiting_for_approval,approved,confirmed,done,cancelled,rejected"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_create_new_costing"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-copy">
                            <span>Copy Costing</span>
                        </button>
                        <button name="%(stock_landed_costs.action_stock_landed_cost)d"
                                type="action"
                                class="oe_stat_button"
                                icon="fa-truck"
                                invisible="not landed_cost_id"
                                context="{'search_default_id': landed_cost_id}">
                            <span class="o_stat_text">Landed Costs</span>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="costing_type" widget="radio" options="{'horizontal': true}"/>
                            <field name="is_marketing_costing"/>
                            <field name="is_deposit_costing"/>
                            <field name="client_id" invisible="not is_marketing_costing"/>
                            <field name="date"/>
                            <field name="purchase_order_id"
                                   options="{'no_create': True, 'no_edit': True}"
                                   domain="[('order_type', '=', 'foreign'), ('state', 'in', ['purchase', 'transit_done'])]"
                                   invisible="is_marketing_costing"
                                   required="not is_marketing_costing"/>
                            <field name="shipment_id" options="{'no_create': True}"/>
                            <field name="landing_id" options="{'no_create': True}"/>
                            <field name="transit_process_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="bank_process_id" options="{'no_create': True, 'no_edit': True}"/>
                            <field name="lc_number_display" readonly="1"/>
                            <field name="lc_date_of_shipment_display" readonly="1"/>
                            <field name="negotiation_expiry_date_display" readonly="1"/>
                            <field name="lc_amount_display" widget="monetary" options="{'currency_field': 'currency_id'}" readonly="1"/>
                            <field name="duty_fx" options="{'no_create': True, 'no_edit': True}"/>
                        </group>
                    </group>
                    
                    <group string="Payment Request Integration" invisible="state not in ['draft', 'calculated']">
                        <field name="payment_request_ids" widget="many2many_tags"
                               domain="[('purchase_order_id', '=', purchase_order_id), ('state', '=', 'paid')]"
                               options="{'no_create': True}"/>
                    </group>
                    
                    <group string="Summary">
                        <group>
                            <field name="total_products"/>
                            <field name="total_quantity"/>
                            <field name="total_landed_cost_fx" widget="monetary" string="Grand Total (Birr)"/>
                        </group>
                        <group>
                            <field name="cost_rate_fx"/>
                            <field name="total_ex_works_usd" widget="monetary" options="{'currency_field': 'duty_fx'}"/>
                            <field name="total_invoice_birr" widget="monetary"/>
                        </group>
                        <group>
                            <!-- Restored margin fields from UI -->
                             <field name="margin_factor_fx"/>
                             <field name="margin_fx" widget="percentage"/>
                             <field name="include_vat"/>
                             <field name="include_withholding"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Exchange Rates &amp; Base Amounts" name="basic_info">
                            <group>
                                <group string="Exchange Rates">
                                    <field name="exchange_rate_fx"
                                            widget="monetary"
                                            options="{'currency_field': 'currency_id'}"/>
                                    <field name="exchange_rate2_fx"
                                            widget="monetary"
                                            options="{'currency_field': 'currency_id'}"/>
                                </group>
                                <group string="Base Amounts (USD)">
                                    <field name="amount_fx" widget="monetary"/>
                                    <field name="fob_charges_fx" widget="monetary"/>
                                    <field name="freight_charge_fx" widget="monetary"/>
                                </group>
                            </group>
                            <group>
                                <group string="Amounts in Birr">
                                    <field name="amount_in_birr_fx" widget="monetary"/>
                                    <field name="ex_works_in_birr_fx" readonly="1" widget="monetary"/>
                                    <field name="fob_charge_in_birr_fx" readonly="1" widget="monetary"/>
                                    <field name="fright_charge_in_birr_fx" readonly="1" widget="monetary"/>
                                </group>
                                <group string="Configuration">
                                    <field name="optimum_values_fx"/>
                                </group>
                            </group>
                        </page>
                        
                        <page string="Banking Charges" name="banking">
                            <group>
                                <group>
                                    <field name="bank_charge_fx" widget="monetary"/>
                                    <field name="bank_charge_of_eslsc_fx" widget="monetary"/>
                                    <field name="bank_interest_fx" widget="monetary"/>
                                </group>
                            </group>
                            <separator string="Banking Charges from Payment Requests (Reference)"/>
                            <field name="payment_cost_line_ids"
                                    domain="[('cost_category', '=', 'banking')]"
                                    readonly="1">
                                <list>
                                    <field name="payment_request_id"/>
                                    <field name="payment_type"/>
                                    <field name="payment_method"/>
                                    <field name="description"/>
                                    <field name="amount_original" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="amount_birr" widget="monetary"/>
                                    <field name="applied_to_cost"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Insurance" name="insurance">
                            <group>
                                <group>
                                    <field name="insurance_amount_fx" widget="monetary"/>
                                    <field name="third_party_fx" widget="monetary"/>
                                    <field name="owen_damage_fx" widget="monetary"/>
                                    <field name="insurance_claim_fx" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="work_mens_fx" widget="monetary"/>
                                    <field name="yellow_card_fx" widget="monetary"/>
                                    <field name="insurance_extension_fx" widget="monetary"/>
                                </group>
                            </group>
                            <separator string="Insurance Costs from Payment Requests (Reference)"/>
                            <field name="payment_cost_line_ids"
                                    domain="[('cost_category', '=', 'insurance')]"
                                    readonly="1">
                                <list>
                                    <field name="payment_request_id"/>
                                    <field name="payment_type"/>
                                    <field name="payment_method"/>
                                    <field name="description"/>
                                    <field name="amount_original" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="amount_birr" widget="monetary"/>
                                    <field name="applied_to_cost"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Port &amp; Transport" name="port_transport">
                            <group>
                                <group>
                                    <field name="container_service_char_fx" widget="monetary"/>
                                    <field name="djibuti_port_expense_fx" widget="monetary"/>
                                    <field name="local_forward_and_clea_fx" widget="monetary"/>
                                    <field name="trans_charge_from_dj_t_fx" widget="monetary"/>
                                    <field name="change_warehouse_fx" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="empty_cont_trans_char_fx" widget="monetary"/>
                                    <field name="trans_charge_to_wareho_fx" widget="monetary"/>
                                    <field name="miscellaneous_fx" widget="monetary"/>
                                    <field name="rta_fx" widget="monetary"/>
                                </group>
                            </group>
                            <separator string="Port &amp; Transport Costs from Payment Requests (Reference)"/>
                            <field name="payment_cost_line_ids"
                                    domain="[('cost_category', '=', 'port_transport')]"
                                    readonly="1">
                                <list>
                                    <field name="payment_request_id"/>
                                    <field name="payment_type"/>
                                    <field name="payment_method"/>
                                    <field name="description"/>
                                    <field name="amount_original" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="amount_birr" widget="monetary"/>
                                    <field name="applied_to_cost"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Taxes &amp; Duties" name="taxes">
                            <group>
                                <group>
                                    <field name="customes_duty_fx" widget="monetary"/>
                                    <field name="vat_amount_fx" widget="monetary"/>
                                    <field name="excise_tax_fx" widget="monetary"/>
                                    <field name="sur_tax_fx" widget="monetary"/>
                                    <field name="withholding_tax_fx" widget="monetary"/>
                                    <field name="social_welfare_fx" widget="monetary"/>
                                </group>
                                <group>
                                    <field name="scanning_fee_fx" widget="monetary"/>
                                    <field name="storage_charge_fx" widget="monetary"/>
                                    <field name="custom_bond_fx" widget="monetary"/>
                                </group>
                            </group>
                            <separator string="Taxes &amp; Duties from Payment Requests (Reference)"/>
                            <field name="payment_cost_line_ids"
                                    domain="[('cost_category', '=', 'taxes_duties')]"
                                    readonly="1">
                                <list>
                                    <field name="payment_request_id"/>
                                    <field name="payment_type"/>
                                    <field name="payment_method"/>
                                    <field name="description"/>
                                    <field name="amount_original" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="amount_birr" widget="monetary"/>
                                    <field name="applied_to_cost"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Cost Calculations" name="calculations">
                            <group>
                                <group string="System Calculated Values" class="oe_read_only">
                                    <field name="total_landed_cost_fx" readonly="1" widget="monetary"/>
                                    <field name="cost_factor_fx" readonly="1"/>
                                    <field name="suggested_cost_rate_fx" readonly="1"/>
                                    <!-- REMOVED: suggested_margin_factor_fx -->
                                </group>
                                <group string="Editable Values" class="oe_edit_only">
                                    <field name="cost_rate_fx"
                                            widget="monetary"
                                            options="{'currency_field': 'currency_id'}"
                                            help="Editable cost rate"/>
                                <!-- Restored margin fields from editable values -->
                                     <!-- Note: the user might want this readonly since it's auto-calculated dynamically, but let's see -->
                                     <!-- <field name="margin_factor_fx" help="Editable margin factor"/> -->
                                     <!-- <field name="margin_fx" widget="percentage" help="Editable margin percentage"/> -->
                                </group>
                            </group>
                        </page>
                        
                        <page string="Additional Costs" name="additional_costs">
                            <p class="text-muted">Add any additional costs not covered by payment requests or standard cost categories.</p>
                            <field name="additional_cost_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="cost_category"/>
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="amount_original" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="amount_birr" readonly="1" widget="monetary"/>
                                    <field name="applied_to_cost"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Product Lines" name="products">
                            <separator string="Product Details (Reference)"/>
                            <field name="product_line_ids" readonly="1">
                                <list>
                                    <field name="product_id"/>
                                    <field name="part_no_fx"/>
                                    <field name="description_of_goods_fx"/>
                                    <field name="total_quantit_imported_fx"/>
                                    <field name="measurmet_unit_fx"/>
                                    <field name="unit_price_fx" widget="monetary"/>
                                    <field name="currency_fx"/>
                                    <field name="cost_rate_fx"/>
                                    <!-- Restored: margin column from product lines display -->
                                    <field name="margin_fx"/>
                                    <field name="unit_cost_in_birr_fx" widget="monetary"/>
                                    <field name="usp_after_vat_in_birr_fx" widget="monetary"/>
                                    <field name="usp_after_vat_manual" widget="monetary" string="ADJ. USP After Vat."/>
                                    <button name="action_view_cost_history" type="object" string="Cost History" icon="fa-history" title="View historical costs of this product"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
               <chatter/>
            </form>
        </field>
    </record>

    <record id="view_foreign_costing_search" model="ir.ui.view">
        <field name="name">foreign.costing.search</field>
        <field name="model">foreign.costing</field>
        <field name="arch" type="xml">
            <search string="Foreign Costings">
                <field name="reference"/>
                <field name="purchase_order_id"/>
                <field name="date"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Calculated" name="calculated" domain="[('state','=','calculated')]"/>
                <filter string="Waiting for Approval" name="waiting_for_approval" domain="[('state','=','waiting_for_approval')]"/>
                <filter string="Approved" name="approved" domain="[('state','=','approved')]"/>
                <filter string="Confirmed" name="confirmed" domain="[('state','=','confirmed')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        domain="[('date','&gt;=',datetime.datetime.now().strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by':'date'}"/>
                    <filter string="Purchase Order" name="group_po" context="{'group_by':'purchase_order_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_foreign_costing" model="ir.actions.act_window">
        <field name="name">Foreign Costings</field>
        <field name="res_model">foreign.costing</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_foreign_costing_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first foreign costing!
            </p>
            <p>
                Manage all costs related to foreign procurement including shipping,
                duties, clearing charges, and calculate total landed costs.
            </p>
        </field>
    </record>

    <record id="view_foreign_costing_kanban" model="ir.ui.view">
        <field name="name">foreign.costing.kanban</field>
        <field name="model">foreign.costing</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="reference"/>
                <field name="date"/>
                <field name="state"/>
                <field name="total_landed_cost_fx"/>
                <field name="cost_rate_fx"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="reference"/>
                                        </strong>
                                    </div>
                                    <span class="badge badge-pill">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="date"/>
                                    <br/>
                                    <strong>Grand Total (Birr): </strong>
                                    <field name="total_landed_cost_fx" widget="monetary"/>
                                    <br/>
                                    <strong>Cost Rate: </strong>
                                    <field name="cost_rate_fx"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
</odoo>