<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payment Request List View -->
    <record id="view_foreign_payment_request_tree" model="ir.ui.view">
        <field name="name">foreign.payment.request.list</field>
        <field name="model">foreign.payment.request</field>
        <field name="arch" type="xml">
            <list string="Foreign Payment Requests">
                <field name="name"/>
                <field name="request_date"/>
                <field name="supplier_id"/>
                <field name="total_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="company_currency_id" invisible="1"/>
                <field name="state" widget="badge"/>
                <field name="days_pending"/>
                <field name="requested_by"/>
            </list>
        </field>
    </record>

    <!-- Payment Request Form View -->
    <record id="view_foreign_payment_request_form" model="ir.ui.view">
        <field name="name">foreign.payment.request.form</field>
        <field name="model">foreign.payment.request</field>
        <field name="arch" type="xml">
            <form string="Foreign Payment Request">
                <header>
                    <field name="is_current_user_approver" invisible="1"/>
                    <button name="action_submit" string="Submit for Approval" type="object" 
                            class="oe_highlight" invisible="state != 'draft'"/>

                    <button name="action_procurement_manager_approve" string="Approve (Procurement)"
                            type="object" class="btn-primary"
                            invisible="not (state == 'waiting_for_procurement_manager' and is_current_user_approver)" />
                    
                    <button name="action_finance_manager_approve" string="Approve (Finance Approval)"
                            type="object" class="btn-primary"
                            invisible="not (state == 'waiting_for_finance_manager' and is_current_user_approver)" />

                    <button name="action_mark_as_paid" string="Mark as Paid" type="object" class="oe_highlight"
                            invisible="state != 'approved'"
                            groups="hagbes_procurement_management.group_foreign_procurement_finance"/>

                    <button name="action_reject" string="Reject" type="object" 
                            class="btn-danger"
                            invisible="not (state in ['waiting_for_procurement_manager', 'waiting_for_finance_manager'] and is_current_user_approver)"/>

                    <button name="action_set_to_draft" string="Reset to Draft" type="object" 
                            invisible="state not in ['rejected','cancelled']"/>

                    <button name="action_cancel" string="Cancel" type="object" 
                            invisible="state in ['paid','cancelled']"/>

                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,waiting_for_procurement_manager,waiting_for_finance_manager,approved,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="purchase_order_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="supplier_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="request_date" readonly="state != 'draft'"/>
                            <field name="required_date"/>
                            <field name="currency_id" readonly="state != 'draft'"/>
                            <field name="journal_id" options="{'no_create': True}" invisible="state not in ['waiting_for_finance_manager', 'approved', 'paid']" required="state == 'waiting_for_finance_manager'"/>

                            <field name="company_currency_id" invisible="1"/>

                        </group>
                    </group>
                    
                    <group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                        </group>
                        <group>
                            <field name="approved_by" readonly="1"/>
                            <field name="approved_date" readonly="1"/>
                        </group>
                    </group>

                    <group string="Approval Progress" invisible="not approval_request_id">
                        <field name="step_progress" widget="html"/>
                    </group>

                    <notebook>
                        <page string="Payment Lines" name="payment_lines">
                            <field name="payment_line_ids" readonly="state != 'draft'">
                                <list editable="bottom" create="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="payment_type"/>
                                    <field name="payment_method"/>
                                    <field name="description"/>
                                    <field name="amount" widget="monetary"/>
                                    <field name="currency_id"/>
                                    <field name="beneficiary"/>
                                    <field name="due_date"/>
                                </list>
                                <form>
                                    <sheet>
                                        <group>
                                            <field name="payment_type"/>
                                            <field name="payment_method"/>
                                            <field name="description"/>
                                            <field name="amount" widget="monetary"/>
                                            <field name="currency_id"/>
                                            <field name="beneficiary"/>
                                            <field name="due_date"/>
                                            <field name="reference"/>
                                            <field name="notes"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_amount" widget="monetary" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>

                                    <page string="Previous Requests">
                <field name="related_request_ids">
                    <list string="Previous Requests">
                    <field name="name"/>
                    <field name="state"/>
                    <field name="request_date"/>
                    <field name="required_date"/>
                    <field name="total_amount" widget="monetary"/>
                    </list>
                </field>
                </page>




                        <page string="Additional Information" name="additional_info">
                            <group>
                                <field name="notes" nolabel="1" placeholder="Additional notes..." readonly="state != 'draft'"/>
                            </group>
                            <group string="Rejection Details" invisible="state != 'rejected'">
                                <field name="rejection_reason" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Payment Request Actions -->
    <record id="action_foreign_payment_request" model="ir.actions.act_window">
        <field name="name">Payment Requests</field>
        <field name="res_model">foreign.payment.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first foreign payment request!
            </p>
            <p>
                Foreign payment requests help you manage and track all payments 
                related to foreign procurement processes.
            </p>
        </field>
    </record>

    <record id="view_foreign_payment_request_form_inherit_lc" model="ir.ui.view">
    <field name="name">foreign.payment.request.form.inherit.lc</field>
    <field name="model">foreign.payment.request</field>
    <field name="inherit_id" ref="view_foreign_payment_request_form"/>
    <field name="arch" type="xml">
        <xpath expr="//sheet/group" position="after">
            <group string="LC Details">
                <field name="lc_amount"/>
                <field name="lc_margin"/>
                <field name="request_amount" readonly="1"/>
            </group>
        </xpath>
    </field>
</record>

</odoo>
