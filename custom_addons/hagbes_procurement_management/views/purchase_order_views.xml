<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Enhanced Purchase Order Form View -->
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <!-- Inherit from the view that adds the 'Receive Products' button -->
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">99</field> <!-- Use a higher priority to apply after other modules -->
        <field name="arch" type="xml">

            <!-- Company and Branch -->
            <xpath expr="//field[@name='partner_id']" position="before">
                <field name="company_id" />
                <field name="branch_id"
                       string="Branch"
                       domain="[('plan_id.name', '=', 'Branch'), ('company_id', '=', company_id)]"
                       context="{'default_company_id': company_id}"
                       readonly="1"/>
            </xpath>

            <!-- Stat buttons with padding -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_purchase_request" type="object"
                        class="oe_stat_button" icon="fa-file-text-o"
                        invisible="not purchase_request_id">
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">Purchase</span>
                        <span class="o_stat_text">Request</span>
                    </div>
                </button>
                <button name="action_view_payment_requests" type="object"
                        class="oe_stat_button" icon="fa-money"
                        style="margin-right: 5px;"
                        invisible="order_type != 'foreign'">
                    <field name="payment_request_count" widget="statinfo" string="Payment Requests"/>
                </button>
                <button name="action_view_shipments" type="object"
                        class="oe_stat_button" icon="fa-ship"
                        style="margin-right: 5px;"
                        invisible="order_type != 'foreign'">
                    <field name="shipment_count" widget="statinfo" string="Shipments"/>
                </button>
                <button name="action_view_costing" type="object"
                        class="oe_stat_button" icon="fa-anchor"
                        style="margin-right: 5px;"
                        invisible="order_type != 'foreign'">
                    <field name="landing_count" widget="statinfo" string="Costing Processes"/>
                </button>
            </xpath>

            <!-- Order type -->
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="order_type" readonly="1"/>
                <field name="purchase_request_id" invisible="not purchase_request_id" readonly="1" force_save="1" options="{'no_open': True}"/>
                <field name="request_overall_status" invisible="not purchase_request_id" widget="badge" decoration-info="1"/>
            </xpath>

            <!-- Foreign Procurement Page -->
            <xpath expr="//notebook" position="inside">
                <page string="Foreign Procurement" name="foreign_procurement"
                      invisible="order_type != 'foreign'">
                    <separator string="Quick Actions"/>
                    <div class="oe_button_box">
                        <button name="action_create_payment_request"
                                string="Create Payment Request"
                                type="object"
                                class="oe_highlight"
                                icon="fa-money"/>
                        <button name="action_create_shipment"
                                string="Create Shipment"
                                type="object"
                                class="oe_highlight"
                                icon="fa-ship"/>
                        <button name="action_create_landing"
                                string="Create Costing Process"
                                type="object"
                                class="oe_highlight"
                                icon="fa-anchor"/>
                    </div>
                </page>
            </xpath>

            <xpath expr="//field[@name='order_line']/form//field[@name='price_unit']" position="after">
                <field name="price_unit_local" 
                       widget="monetary" 
                       options="{'currency_field': 'local_currency_id'}"
                       string="Unit Price (Local)"
                       invisible="order_id.order_type == 'local'"
                       readonly="1"/>
                <field name="price_subtotal_local" 
                       widget="monetary" 
                       options="{'currency_field': 'local_currency_id'}"
                       string="Subtotal (Local)"
                       invisible="order_id.order_type == 'local'"
                       readonly="1"/>
            </xpath>

            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="context">{'tree_view_ref': 'hagbes_procurement_management.view_purchase_order_line_list_custom'}</attribute>
            </xpath>

            <xpath expr="//page[@name='purchase_delivery_invoice']//group[@name='other_info']//field[@name='company_id']" position="replace"/>

            <!-- Hide Extraneous Native Buttons for Foreign POs -->
            <xpath expr="//header/button[@name='action_rfq_send'][1]" position="attributes">
                <attribute name="invisible">state != 'draft' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_rfq_send'][2]" position="attributes">
                <attribute name="invisible">state != 'sent' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_rfq_send'][3]" position="attributes">
                <attribute name="invisible">state != 'purchase' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='print_quotation'][1]" position="attributes">
                <attribute name="invisible">state != 'draft' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='print_quotation'][2]" position="attributes">
                <attribute name="invisible">state != 'sent' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='button_approve']" position="attributes">
                <attribute name="invisible">state != 'to approve' or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='confirm_reminder_mail']" position="attributes">
                <attribute name="invisible">state not in ('purchase', 'done') or mail_reminder_confirmed or not date_planned or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_create_invoice'][1]" position="attributes">
                <attribute name="invisible">state not in ('purchase', 'done') or invoice_status in ('no', 'invoiced') or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//header/button[@name='action_create_invoice'][2]" position="attributes">
                <attribute name="invisible">state not in ('purchase', 'done') or invoice_status not in ('no', 'invoiced') or not order_line or order_type == 'foreign'</attribute>
            </xpath>
            <!-- Hide Receive Products Buttons for Foreign POs -->
            <xpath expr="//header/button[@name='action_view_picking']" position="attributes">
                <attribute name="invisible">is_shipped or state not in ('purchase', 'done') or incoming_picking_count == 0 or order_type == 'foreign'</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']/button[@name='action_view_picking']" position="attributes">
                <attribute name="invisible">incoming_picking_count == 0 or order_type == 'foreign'</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="document_order_number"/>
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_line_list_custom" model="ir.ui.view">
        <field name="name">purchase.order.line.list.custom</field>
        <field name="model">purchase.order.line</field>
        <field name="arch" type="xml">
            <list string="Purchase Order Lines" editable="bottom">
                <field name="product_id" required="1" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="name"/>
                <field name="date_planned" widget="date"/>
                <field name="hs_code" optional="show"/>
                <field name="country_of_origin" optional="show"/>
                <field name="product_qty"/>
                <field name="product_uom" groups="uom.group_uom"/>
                
                <!-- Enhanced unit price display with combined foreign/local for foreign orders -->
                <field name="price_unit" 
                       widget="monetary" 
                       options="{'currency_field': 'currency_id'}"
                       string="Unit Price"
                       invisible="order_id.order_type == 'foreign'"/>
                       
                <!-- For foreign orders: show combined price display -->
                <field name="price_unit" 
                       widget="monetary" 
                       options="{'currency_field': 'currency_id'}"
                       string="Unit Price (Foreign)"
                       invisible="order_id.order_type == 'local'"
                       decoration-info="1"/>
                       
                <field name="price_unit_local" 
                       widget="monetary" 
                       options="{'currency_field': 'local_currency_id'}"
                       string="Unit Price (Local)"
                       invisible="order_id.order_type == 'local'"
                       readonly="1"
                       decoration-muted="1"/>
                
                <field name="taxes_id" widget="many2many_tags" optional="show"/>
                
                <field name="price_subtotal" 
                       widget="monetary" 
                       options="{'currency_field': 'currency_id'}"
                       string="Amount"
                       readonly="1"/>
                
                <field name="landed_cost_allocated" widget="monetary" optional="hide"/>
                <field name="total_cost_per_unit" widget="monetary" optional="hide"/>
                <field name="currency_id" invisible="1"/>
                <field name="local_currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Prevent vendor creation in form -->
    <record id="view_purchase_order_form_inherit_no_create_partner" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.no.create.partner</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True}</attribute>
                <attribute name="domain">[('supplier_rank', '&gt;', 0)]</attribute>
            </xpath>
        </field>
    </record>


    <record id="view_purchase_order_tree_inherit_no_create" model="ir.ui.view">
        <field name="name">purchase.order.tree.inherit.no.create</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_tree"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
        </field>
    </record>
    <record id="view_purchase_order_form_inherit_no_create" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.no.create</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase_stock.purchase_order_view_form_inherit"/>
        <field name="priority">30</field>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="create">false</attribute>
            </xpath>
        </field>
    </record>

</odoo>
