<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Purchase Request Form View -->
    <record id="view_purchase_request_form" model="ir.ui.view">
        <field name="name">purchase.request.form</field>
        <field name="model">purchase.request</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Purchase Request">
                <header>
                    <!-- Invisible fields for controlling button visibility -->
                    <field name="is_current_approver" invisible="1"/>
                    
                    <!-- Print RFQ: only in draft -->
                    <button name="action_print_rfq" type="object" string="Print/Send RFQ" 
                            class="oe_highlight" invisible="state != 'draft'" groups="purchase.group_purchase_user"/>

                    <button name="action_pfi_received" type="object" string="PFI Received" 
                            class="oe_highlight" invisible="state != 'rfq_sent'" groups="purchase.group_purchase_user"/>

                    <!-- Submit for Approval: only after PFI received for foreign, or draft for local -->
                    <button name="action_submit" type="object" string="Confirm/Submit Request" 
                            class="oe_highlight" invisible="request_type == 'foreign' and state != 'pfi_received' or request_type == 'local' and state != 'draft'" groups="purchase.group_purchase_user"/>
                    
                    <!-- Cancel button -->
                    <button name="action_cancel" type="object" string="Cancel" 
                            class="btn-secondary" 
                            invisible="state not in ['draft', 'rfq_sent', 'pfi_received', 'rejected']"/>
                    
                    <!-- Specific Approval Buttons like in foreign.costing -->
                    <button name="action_dept_manager_approve" string="Approve (Department Manager)"
                            type="object" class="btn-primary" disable_on_click="True"
                            invisible="not (state == 'waiting_for_dept_manager' and is_current_user_approver)" />

                    <button name="action_gm_approve" string="Approve (General Manager)"
                            type="object" class="btn-primary" disable_on_click="True"
                            invisible="not (state == 'waiting_for_gm' and is_current_user_approver)" />

                    <button name="action_director_approve" string="Approve (Director)"
                            type="object" class="btn-primary" disable_on_click="True"
                            invisible="not (state == 'waiting_for_director' and is_current_user_approver)" />

                    <button name="action_procurement_manager_approve" string="Approve (Procurement Manager)"
                            type="object" class="btn-primary" disable_on_click="True"
                            invisible="not (state == 'waiting_for_procurement_manager' and is_current_user_approver)" />
                    
                    <!-- Generic Reject Button -->
                    <button name="action_reject" type="object" string="Reject" 
                            class="btn-danger" disable_on_click="True"
                            invisible="not (state in ['waiting_for_dept_manager', 'waiting_for_gm', 'waiting_for_director', 'waiting_for_procurement_manager'] and is_current_user_approver)"/>


                    <!-- Convert to RFQ / Bank Process -->
                    <button name="action_create_bank_process" type="object" string="Create Bank Process"
                            class="oe_highlight" 
                            groups="hagbes_procurement_management.group_foreign_procurement_manager" 
                            invisible="state != 'approved'"/>
                    
                    <!-- Status Bar -->
                    <field name="state" widget="statusbar" 
                           statusbar_visible="draft,rfq_sent,pfi_received,waiting_for_dept_manager,waiting_for_procurement_manager,approved,in_bank_process"/>
                    
                    <!-- Moved justification to header area -->
                    <!-- <group>
                        <group>
                            <field name="justification" placeholder="Provide detailed justification for this purchase request..." 
                                   readonly="state != 'draft'" string="Justification/Remark" 
                                   widget="text" style="width: 100%; min-height: 60px;"/>
                        </group>
                    </group> -->
                </header>
                
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_rfqs" type="object" class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="rfq_count" widget="statinfo" string="RFQs"/>
                        </button>
                        <button name="action_view_pos" type="object" class="oe_stat_button" icon="fa-check-square-o">
                            <field name="po_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                    </div>
                    
                    <!-- Enhanced approval info display with better visibility -->
                    <div class="alert alert-info" invisible="state == 'draft'">
                        <div invisible="not current_step_name">
                            <strong>Current Step:</strong> <field name="current_step_name" readonly="1"/>
                        </div>
                        <div invisible="not current_approver_name">
                            <strong>Current Approver:</strong> <field name="current_approver_name" readonly="1"/>
                        </div>
                        <div invisible="is_current_approver == False" class="text-success">
                            <strong>✓ You are the current approver for this request</strong>
                        </div>
                        <div invisible="state != 'pending'" class="text-warning">
                            <strong>⏳ Waiting for approval...</strong>
                        </div>
                    </div>
                    
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="requested_by" readonly="1"/>
                            <field name="department_id" readonly="1"/>
                            <field name="branch_id" />
                            <field name="request_date" readonly="1"/>
                        </group>
                        <group>
                            <field name="request_type" readonly="1"/>
                            <!-- Made these fields readonly after submission -->
                            <field name="priority" readonly="state != 'draft'"/>
                            <field name="vendor_id" domain="[('supplier_rank','>',0)]" 
                                   options="{'no_create': True}" string="Vendor" readonly="state != 'draft'"/>
                            <field name="vendor_ref" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="required_date" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="currency_id" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="picking_type_id" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="pfi_attachment" filename="pfi_attachment_name" widget="binary" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')" invisible="request_type != 'foreign'" required="0"/>
                            <field name="pfi_attachment_name" invisible="1"/>

                        </group>
                    </group>
                    
                    <group string="Foreign Procurement Details" invisible="request_type != 'foreign'">
                        <group>
                            <field name="incoterm_id" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="origin_id" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="delivery_date" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="validity_period" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                        </group>
                        <group>
                            <field name="insurance" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                            <field name="major_conditions" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')"/>
                        </group>
                    </group>
                    
                    <group>
    <group>
        <field name="justification" placeholder="Provide detailed justification for this purchase request..." 
               readonly="state != 'draft'" string="Justification/Remark" 
               widget="text" style="width: 100%; min-height: 60px;"/>
    </group>
</group>
                    <!-- Added total amount field for approval conditions -->
                    <group>
                        <group>
                            <field name="amount_total" readonly="1" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                        </group>
                        <group>
                            <field name="overall_status" class="oe_inline font-weight-bold" readonly="1" string="Actual Lifecycle Status"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Request Lines">
                            <field name="request_line_ids" readonly="state not in ('draft', 'rfq_sent', 'pfi_received')">
                                <list>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="quantity"/>
                                    <field name="uom_id"/>
                                    <field name="hs_code"/>
                                    <field name="estimated_price" required="1" string="FOB Price"/>
                                    <field name="estimated_total"/>
                                    <field name="required_date"/>
                                </list>
                            </field>
                        </page>
                        
                        <page string="Additional Information">
                            <group readonly="state not in ('draft', 'rfq_sent', 'pfi_received')">
                                <field name="delivery_address" placeholder="Delivery address..."/>
                                <field name="notes" placeholder="Additional notes..."/>
                            </group>
                        </page>
                        
                        <!-- Simplified approval progress using central system -->
                        <page string="Approval Progress" invisible="not approval_request_id">
                            <field name="step_progress" widget="html"/>
                        </page>
                    </notebook>
                </sheet>
                
              
               <chatter/>
            </form>
        </field>
    </record>

    <!-- Purchase Request Line List View -->
    <record id="view_purchase_request_line_list" model="ir.ui.view">
        <field name="name">purchase.request.line.list</field>
        <field name="model">purchase.request.line</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="hs_code"/>
                <field name="estimated_price" required="1" string="FOB Price"/>
                <field name="estimated_total"/>
                <field name="required_date"/>
            </list>
        </field>
    </record>

    <!-- Purchase Request Line Form View -->
    <record id="view_purchase_request_line_form" model="ir.ui.view">
        <field name="name">purchase.request.line.form</field>
        <field name="model">purchase.request.line</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="quantity"/>
                        <field name="uom_id"/>
                        <field name="hs_code"/>
                        <field name="estimated_price" required="1" string="FOB Price"/>
                        <field name="estimated_total"/>
                        <field name="required_date"/>
                        <field name="specifications"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Purchase Request List View -->
    <record id="view_purchase_request_list" model="ir.ui.view">
        <field name="name">purchase.request.list</field>
        <field name="model">purchase.request</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list string="Purchase Requests" decoration-info="state=='draft'"
                  decoration-warning="state in ['pending', 'waiting_for_dept_manager', 'waiting_for_gm', 'waiting_for_director', 'waiting_for_procurement_manager']"
                  decoration-success="state=='approved'">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="department_id"/>
                <field name="branch_id"/>
                <field name="request_date"/>
                <field name="request_type"/>
                <field name="priority"/>
                <!-- Removed justification from list view since it's now in header -->
                <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="current_step_name"/>
                <field name="overall_status"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Purchase Request Search View -->
    <record id="view_purchase_request_search" model="ir.ui.view">
        <field name="name">purchase.request.search</field>
        <field name="model">purchase.request</field>
        <field name="type">search</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Requests">
                <field name="name"/>
                <field name="requested_by"/>
                <field name="department_id"/>
                <field name="justification"/>
                <!-- Added filters for current approver -->
                <filter string="My Requests" name="my_requests" domain="[('requested_by', '=', uid)]"/>
                <filter string="I Can Approve" name="can_approve" domain="[('can_approve', '=', True)]"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Pending Approval" name="pending" domain="[('state', 'in', ['pending', 'waiting_for_dept_manager', 'waiting_for_gm', 'waiting_for_director', 'waiting_for_procurement_manager'])]"/>
                <filter string="Approved" name="approved" domain="[('state', '=', 'approved')]"/>
                <filter string="Foreign Purchase" name="foreign" domain="[('request_type', '=', 'foreign')]"/>
                <filter string="High Priority" name="high_priority" domain="[('priority', 'in', ['high', 'urgent'])]"/>
                <separator/>
                <filter string="This Month" name="this_month" 
                        domain="[('request_date', '>=', (context_today() - relativedelta(months=1)).strftime('%Y-%m-01'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Requested By" name="group_requested_by" context="{'group_by': 'requested_by'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Request Date" name="group_date" context="{'group_by': 'request_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Purchase Request Actions -->
    <record id="action_purchase_request" model="ir.actions.act_window">
        <field name="name">Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first purchase request!
            </p>
            <p>
                Start the procurement process by creating a purchase request that will go through the centralized approval workflow.
            </p>
        </field>
    </record>

    <record id="action_purchase_request_my" model="ir.actions.act_window">
        <field name="name">My Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('requested_by', '=', uid)]</field>
        <field name="context">{'search_default_my_requests': 1}</field>
    </record>

    <record id="action_purchase_request_pending" model="ir.actions.act_window">
        <field name="name">Pending Purchase Requests</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', 'in', ['pending', 'waiting_for_dept_manager', 'waiting_for_gm', 'waiting_for_director', 'waiting_for_procurement_manager'])]</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <!-- Added action for requests I can approve -->
    <record id="action_purchase_request_to_approve" model="ir.actions.act_window">
        <field name="name">Requests to Approve</field>
        <field name="res_model">purchase.request</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('can_approve', '=', True)]</field>
        <field name="context">{'search_default_can_approve': 1}</field>
    </record>

    <!-- Purchase Request Line Views -->
    <record id="view_purchase_request_line_list" model="ir.ui.view">
        <field name="name">purchase.request.line.list</field>
        <field name="model">purchase.request.line</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="product_id"/>
                <field name="description"/>
                <field name="quantity"/>
                <field name="uom_id"/>
                <field name="hs_code"/>
                <field name="estimated_price" required="1" string="FOB Price"/>
                <field name="estimated_total"/>
                <field name="required_date"/>
            </list>
        </field>
    </record>

    <record id="view_purchase_request_line_form" model="ir.ui.view">
        <field name="name">purchase.request.line.form</field>
        <field name="model">purchase.request.line</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_id"/>
                        <field name="description"/>
                        <field name="quantity"/>
                        <field name="uom_id"/>
                        <field name="hs_code"/>
                        <field name="estimated_price" required="1" string="FOB Price"/>
                        <field name="estimated_total"/>
                        <field name="required_date"/>
                        <field name="specifications"/>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
