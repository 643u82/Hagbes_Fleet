<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_manual_inventory_entry_form" model="ir.ui.view">
        <field name="name">manual.inventory.entry.form</field>
        <field name="model">manual.inventory.entry</field>
        <field name="arch" type="xml">
            <form string="Manual Inventory Entry">
                <header>
                    <button name="action_apply" string="Apply" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Product Information">
                            <field name="product_id" readonly="state == 'done'"/>
                            <field name="part_number" readonly="state == 'done'"/>
                            <field name="product_name" readonly="state == 'done'"/>
                            <field name="product_category_id" readonly="state == 'done'"/>
                        </group>
                        <group string="Costing &amp; Pricing">
                            <field name="procurement_type" readonly="state == 'done'" widget="radio" options="{'horizontal': true}"/>
                            <field name="warehouse_cost" readonly="state == 'done'"/>
                            <field name="selling_price" readonly="state == 'done'"/>
                        </group>
                        <group string="Inventory Operations">
                            <field name="warehouse_id" readonly="state == 'done'"/>
                            <field name="location_id" readonly="state == 'done'"/>
                            <field name="quantity" readonly="state == 'done'"/>
                        </group>
                    </group>
                    <group>
                        <field name="remark" placeholder="Add an optional remark..." readonly="state == 'done'"/>
                    </group>
                </sheet>
              <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View -->
    <record id="view_manual_inventory_entry_tree" model="ir.ui.view">
        <field name="name">manual.inventory.entry.list</field>
        <field name="model">manual.inventory.entry</field>
        <field name="arch" type="xml">
            <list string="Manual Inventory Entries" decoration-info="state == 'draft'" decoration-success="state == 'done'">
                <field name="name"/>
                <field name="procurement_type"/>
                <field name="part_number"/>
                <field name="product_name" optional="show"/>
                <field name="quantity"/>
                <field name="warehouse_cost" optional="show"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_manual_inventory_entry_search" model="ir.ui.view">
        <field name="name">manual.inventory.entry.search</field>
        <field name="model">manual.inventory.entry</field>
        <field name="arch" type="xml">
            <search string="Manual Inventory Entry">
                <field name="name"/>
                <field name="part_number"/>
                <field name="product_name"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Done" name="done" domain="[('state', '=', 'done')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="Procurement Type" name="group_by_procurement_type" context="{'group_by': 'procurement_type'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_manual_inventory_entry" model="ir.actions.act_window">
        <field name="name">Manual Inventory Entry</field>
        <field name="res_model">manual.inventory.entry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_manual_inventory_entry_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Manual Inventory Entry!
            </p>
            <p>
                Use this to manually input purchased inventories until local/foreign processes are live.
            </p>
        </field>
    </record>

</odoo>
