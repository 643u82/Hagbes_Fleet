<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Cron Job for AIS Tracking Updates -->
        <record id="cron_update_ship_positions" model="ir.cron">
            <field name="name">Update Ship Positions via AIS</field>
            <field name="model_id" ref="model_foreign_shipment"/>
            <field name="state">code</field>
            <field name="code">model.cron_update_all_tracking_vessels()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
