<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
            <!-- Foreign Shipment Sequence -->
        <record id="seq_foreign_shipment" model="ir.sequence">
            <field name="name">Foreign Shipment</field>
            <field name="code">foreign.shipment</field>
            <field name="prefix">SH/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>
      

        <!-- Foreign Costing Sequence -->
           <record id="seq_foreign_costing" model="ir.sequence">
            <field name="name">Foreign Costing</field>
            <field name="code">foreign.costing</field>
            <field name="prefix">FC</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- Purchase Order Sequence -->
        
         <record id="seq_purchase_order" model="ir.sequence">
        <field name="name">Purchase Order</field>
        <field name="code">purchase.order</field>
        <field name="prefix">P%(year)s</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
         </record>
         
        <!-- Sequence for Foreign Payment Request -->
        <record id="seq_foreign_payment_request" model="ir.sequence">
       <field name="name">Foreign Payment Request</field>
       <field name="code">foreign.payment.request.new_sequence_code</field>
       <field name="prefix"/>
       <field name="padding">5</field>
       <field name="number_next">1</field>
       <field name="number_increment">1</field>
       </record>
        <!-- Sequence for Foreign Transit Process -->
        <record id="seq_foreign_transit_process" model="ir.sequence">
       <field name="name">Foreign Transit Process</field>
       <field name="code">foreign.transit.process</field>
       <field name="prefix"/>
       <field name="padding">5</field>
       <field name="number_next">1</field>
       <field name="number_increment">1</field>
      </record>

         <!-- Sequence for Foreign Bank Process -->
        <record id="seq_foreign_bank_process" model="ir.sequence">
            <field name="name">Foreign Bank Process</field>
            <field name="code">foreign.bank.process</field>
            <field name="prefix"/>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
         <!-- Sequence for Purchase Request -->
            <record id="seq_purchase_request" model="ir.sequence">
            <field name="name">Purchase Request</field>
            <field name="code">purchase.request</field>
            <field name="prefix"/>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <!-- Sequence for Local Purchase Request -->
            <record id="seq_local_purchase_request" model="ir.sequence">
            <field name="name">Local Purchase Request</field>
            <field name="code">local.purchase.request</field>
            <field name="prefix"/>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
        <!-- Sequence for Manual Inventory -->
        <record id="seq_manual_inventory_entry" model="ir.sequence">
            <field name="name">Manual Inventory Entry</field>
            <field name="code">manual.inventory.entry</field>
            <field name="prefix">MINT/</field>
            <field name="padding">5</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>
    </data>

        <!-- Cron job to update transit positions -->
    <data noupdate="1">
        <record id="ir_cron_update_transit_positions" model="ir.cron">
            <field name="name">Transit: Update Vessel Positions</field>
            <field name="model_id" ref="hagbes_procurement_management.model_foreign_transit_process"/>
            <field name="code">model.cron_update_all_tracking_transits()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
