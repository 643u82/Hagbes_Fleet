<odoo>
    <record id="view_approval_remark_wizard_form" model="ir.ui.view">
        <field name="name">approval.remark.wizard.form</field>
        <field name="model">approval.remark.wizard</field>
        <field name="arch" type="xml">
            <form string="Approval Remark">
                <group>
                    <field name="comment" placeholder="Write your remark..." nolabel="1"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
