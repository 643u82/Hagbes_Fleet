<?xml version="1.0" encoding="utf-8"?>
<odoo>
   
    <record id="view_product_group_tree" model="ir.ui.view">
        <field name="name">product.group.tree</field>
        <field name="model">product.group</field>
        <field name="arch" type="xml">
            <list string="Product Groups">
                <field name="code"/>
                <field name="name"/>
                <field name="parent_id"/>
                <field name="default_markup_percent" widget="percentage"/>
                <field name="product_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    
    <record id="view_product_group_form" model="ir.ui.view">
        <field name="name">product.group.form</field>
        <field name="model">product.group</field>
        <field name="arch" type="xml">
            <form string="Product Group">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_product_price_update_wizard)d" 
                                type="action" 
                                class="oe_stat_button" 
                                icon="fa-tags"
                                context="{'default_product_group_ids': [(6, 0, [id])]}">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Update Prices</span>
                            </div>
                        </button>
                        <button name="action_view_products" class="oe_stat_button" type="object" icon="fa-cubes">
                            <field name="product_count" widget="statinfo" string="Products"/>
                        </button>
                    </div>
                    
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" 
                            invisible="active"/>
                    
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Group Name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="default_markup_percent" widget="percentage"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Description">
                            <field name="description" placeholder="Group description..."/>
                        </page>
                        <page string="Child Groups" invisible="not child_ids">
                            <field name="child_ids">
                                <list>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="default_markup_percent" widget="percentage"/>
                                    <field name="product_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

   
    <record id="action_product_group" model="ir.actions.act_window">
        <field name="name">Product Groups</field>
        <field name="res_model">product.group</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first product group!
            </p>
            <p>
                Product groups help you organize products for bulk price updates and management.
                You can set default markup percentages and apply price changes to entire groups.
            </p>
        </field>
    </record>
</odoo>
