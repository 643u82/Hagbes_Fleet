<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Product Template Form View Inheritance -->
    <record id="view_product_template_form_inherit_price_update" model="ir.ui.view">
        <field name="name">product.template.form.inherit.price.update</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
         
            <xpath expr="//page[@name='sales']//group[@name='sale']" position="after">
                <group string="Price Management" name="price_management">
                    <field name="min_margin_percent"/>
                    <field name="max_margin_percent"/>
                    <field name="last_price_update" readonly="1"/>
                </group>
            </xpath>
            
          
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_price_history" 
                        type="object" 
                        class="oe_stat_button" 
                        icon="fa-history"
                        invisible="price_history_count == 0">
                    <field name="price_history_count" widget="statinfo" string="Price Changes"/>
                </button>
            </xpath>
            
         
            <xpath expr="//notebook" position="inside">
                <page string="Price History" name="price_history" invisible="price_history_count == 0">
                    <field name="price_history_ids" readonly="1">
                        <list>
                            <field name="update_date"/>
                            <field name="old_price" widget="monetary"/>
                            <field name="new_price" widget="monetary"/>
                            <field name="price_difference" widget="monetary"/>
                            <field name="updated_by"/>
                            <field name="update_type"/>
                            <field name="reason"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
