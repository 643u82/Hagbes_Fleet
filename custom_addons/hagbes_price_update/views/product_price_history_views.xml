<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Price History Tree View -->
    <record id="view_product_price_history_tree" model="ir.ui.view">
        <field name="name">product.price.history.tree</field>
        <field name="model">product.price.history</field>
        <field name="arch" type="xml">
            <list string="Price History" default_order="update_date desc">
                <field name="update_date"/>
                <field name="product_id"/>
                <field name="old_price" widget="monetary"/>
                <field name="new_price" widget="monetary"/>
                <field name="price_difference" widget="monetary" 
                       decoration-success="price_difference &gt; 0"
                       decoration-danger="price_difference &lt; 0"/>
                <field name="price_change_percent" widget="percentage"/>
                <field name="updated_by"/>
                <field name="update_type"/>
                <field name="reason"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    
    <record id="view_product_price_history_form" model="ir.ui.view">
        <field name="name">product.price.history.form</field>
        <field name="model">product.price.history</field>
        <field name="arch" type="xml">
            <form string="Price History" create="false" edit="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group string="Product Information">
                            <field name="product_id"/>
                            <field name="product_template_id"/>
                            <field name="currency_id"/>
                        </group>
                        
                        <group string="Price Changes">
                            <field name="old_price" widget="monetary"/>
                            <field name="new_price" widget="monetary"/>
                            <field name="price_difference" widget="monetary"/>
                            <field name="price_change_percent" widget="percentage"/>
                        </group>
                    </group>
                    
                    <group>
                        <group string="Update Information">
                            <field name="update_date"/>
                            <field name="updated_by"/>
                            <field name="update_type"/>
                        </group>
                    </group>
                    
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

  
    <record id="view_product_price_history_search" model="ir.ui.view">
        <field name="name">product.price.history.search</field>
        <field name="model">product.price.history</field>
        <field name="arch" type="xml">
            <search string="Price History">
                <field name="product_id"/>
                <field name="updated_by"/>
                <field name="reason"/>
                
               <!-- <filter string="Today" name="today" 
        domain="[('update_date', '&gt;=', datetime.datetime.combine(context_today(), datetime.time(0,0,0)))]"/>
<filter string="This Week" name="this_week" 
        domain="[('update_date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
<filter string="This Month" name="this_month" 
        domain="[('update_date', '&gt;=', (context_today().replace(day=1)).strftime('%Y-%m-%d'))]"/> -->

                
                <separator/>
                <filter string="Price Increases" name="price_increases" 
                        domain="[('price_difference', '&gt;', 0)]"/>
                <filter string="Price Decreases" name="price_decreases" 
                        domain="[('price_difference', '&lt;', 0)]"/>
                
                <separator/>
                <filter string="Manual Updates" name="manual_updates" 
                        domain="[('update_type', '=', 'manual')]"/>
                <filter string="Bulk Updates" name="bulk_updates" 
                        domain="[('update_type', '=', 'bulk')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Product" name="group_product" context="{'group_by': 'product_id'}"/>
                    <filter string="Updated By" name="group_user" context="{'group_by': 'updated_by'}"/>
                    <filter string="Update Type" name="group_type" context="{'group_by': 'update_type'}"/>
                    <filter string="Update Date" name="group_date" context="{'group_by': 'update_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Price History Action -->
    <record id="action_product_price_history" model="ir.actions.act_window">
        <field name="name">Price History</field>
        <field name="res_model">product.price.history</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_product_price_history_search"/>
        <field name="context">{'search_default_this_month': 1}</field>
    </record>
</odoo>
