<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
      
        <record id="demo_price_history_1" model="product.price.history">
            <field name="product_id" ref="product.product_product_4"/>
            <field name="product_template_id" ref="product.product_product_4_product_template"/>
            <field name="old_price">100.00</field>
            <field name="new_price">110.00</field>
            <field name="reason">Seasonal price increase</field>
            <field name="update_type">manual</field>
            <field name="updated_by" ref="base.user_admin"/>
        </record>

        <record id="demo_price_history_2" model="product.price.history">
            <field name="product_id" ref="product.product_product_5"/>
            <field name="product_template_id" ref="product.product_product_5_product_template"/>
            <field name="old_price">50.00</field>
            <field name="new_price">45.00</field>
            <field name="reason">Promotional discount</field>
            <field name="update_type">bulk</field>
            <field name="updated_by" ref="base.user_admin"/>
        </record>

        <record id="demo_product_margin_limits" model="product.template">
            <field name="name">Demo Product with Margin Limits</field>
            <field name="type">consu</field>
            <field name="list_price">150.00</field>
            <field name="standard_price">100.00</field>
            <field name="min_margin_percent">20.0</field>
            <field name="max_margin_percent">50.0</field>
        </record>

    </data>
</odoo>
