<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Price Update Security Groups -->
        <record id="group_price_update_user" model="res.groups">
            <field name="name">Price Update User</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Can view and update product prices with basic restrictions</field>
        </record>

        <record id="group_price_update_manager" model="res.groups">
            <field name="name">Price Update Manager</field>
            <field name="category_id" ref="base.module_category_sales"/>
            <field name="implied_ids" eval="[(4, ref('group_price_update_user'))]"/>
            <field name="comment">Can perform bulk price updates and manage price history without restrictions</field>
        </record>

        <!-- Record Rules for Price History -->
        <record id="rule_product_price_history_user" model="ir.rule">
            <field name="name">Price History: User Access</field>
            <field name="model_id" ref="model_product_price_history"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_price_update_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_product_price_history_manager" model="ir.rule">
            <field name="name">Price History: Manager Access</field>
            <field name="model_id" ref="model_product_price_history"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_price_update_manager'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules for Price Update Wizard -->
        <record id="rule_product_price_update_wizard_own" model="ir.rule">
            <field name="name">Price Update Wizard: Own Records</field>
            <field name="model_id" ref="model_product_price_update_wizard"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_price_update_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Explicit access for Price Update Manager to product.price.history -->
        <record id="access_product_price_history_price_update_manager" model="ir.model.access">
            <field name="name">product.price.history.price_update.manager</field>
            <field name="model_id" ref="model_product_price_history"/>
            <field name="group_id" ref="group_price_update_manager"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

    </data>
</odoo>
