<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="TrialBalanceTemp">
        <div class="o_action account_report h-100 d-flex flex-column overflow-hidden">
            <!-- CONTROL PANEL -->
            <div class="o_control_panel d-flex flex-column gap-3 px-3 pt-2 pb-3 border-bottom">
                <div class="o_control_panel_main d-flex flex-wrap flex-lg-nowrap justify-content-between align-items-lg-start gap-2 gap-lg-3 flex-grow-1">
                    
                    <!-- Breadcrumbs -->
                    <div class="o_control_panel_breadcrumbs d-flex align-items-center gap-1 order-0 h-lg-100">
                        <div class="o_control_panel_main_buttons d-flex gap-1 d-empty-none d-print-none">
                            <button class="btn text-nowrap btn-primary" t-on-click="print_pdf">PDF</button>
                            <button class="btn text-nowrap btn-secondary">XLSX</button>
                        </div>
                        <div class="o_breadcrumb d-flex gap-1 text-truncate">
                            <div class="o_last_breadcrumb_item active d-flex fs-4 min-w-0 align-items-center">
                                <span class="min-w-0 text-truncate">Trial Balance</span>
                            </div>
                        </div>
                    </div>

                    <!-- Filters -->
                    <div class="o_control_panel_actions d-empty-none d-flex align-items-center justify-content-start justify-content-lg-around order-2 order-lg-1 w-100 mw-100 w-lg-auto">
                        <div class="d-flex gap-1">
                            <!-- Date Filter -->
                            <Dropdown>
                                <button class="btn btn-secondary o-dropdown dropdown-toggle">
                                    <i class="fa fa-calendar me-1"/>
                                    <t t-if="state.date_filter === 'custom'">Custom</t>
                                    <t t-else=""><t t-esc="formatDate(state.date_to)"/></t>
                                </button>
                                <t t-set-slot="content">
                                    <DropdownItem onSelected="() => this.onFilterTypeChanged('month')" class="state.date_filter === 'month' ? 'selected' : ''">Month</DropdownItem>
                                    <DropdownItem onSelected="() => this.onFilterTypeChanged('quarter')" class="state.date_filter === 'quarter' ? 'selected' : ''">Quarter</DropdownItem>
                                    <DropdownItem onSelected="() => this.onFilterTypeChanged('year')" class="state.date_filter === 'year' ? 'selected' : ''">Year</DropdownItem>
                                    <DropdownItem onSelected="() => this.onFilterTypeChanged('custom')" class="state.date_filter === 'custom' ? 'selected' : ''">Custom</DropdownItem>
                                    
                                    <div class="p-2" t-if="state.date_filter === 'custom'">
                                        <div class="mb-2">
                                            <label class="small text-muted">From:</label>
                                            <DateTimePicker value="state.date_from" onSelect="(d) => this.onCustomDateFromChanged(d)"/>
                                        </div>
                                        <div>
                                            <label class="small text-muted">To:</label>
                                            <DateTimePicker value="state.date_to" onSelect="(d) => this.onCustomDateToChanged(d)"/>
                                        </div>
                                    </div>
                                </t>
                            </Dropdown>

                            <!-- Comparison Filter -->
                            <Dropdown>
                                <button class="btn btn-secondary o-dropdown dropdown-toggle">
                                    <i class="fa fa-percent me-1"/>
                                    <span>Comparison</span>
                                </button>
                                <t t-set-slot="content">
                                    <DropdownItem onSelected="() => this.onComparisonOptionChanged('no_comparison')" class="state.comparison_option === 'no_comparison' ? 'selected' : ''">No Comparison</DropdownItem>
                                    <DropdownItem onSelected="() => this.onComparisonOptionChanged('previous_period')" class="state.comparison_option === 'previous_period' ? 'selected' : ''">Previous Period</DropdownItem>
                                    <DropdownItem onSelected="() => this.onComparisonOptionChanged('same_last_year')" class="state.comparison_option === 'same_last_year' ? 'selected' : ''">Same Period Last Year</DropdownItem>
                                    <DropdownItem onSelected="() => this.onComparisonOptionChanged('custom')" class="state.comparison_option === 'custom' ? 'selected' : ''">Custom Dates</DropdownItem>
                                    <div t-if="state.comparison_option === 'custom'" class="p-2 border-top">
                                        <DateTimePicker value="state.comparison_date" onSelect="(d) => this.onComparisonDateChanged(d)"/>
                                    </div>
                                </t>
                            </Dropdown>

                            <!-- Journals Filter -->
                            <Dropdown>
                                <button class="btn btn-secondary o-dropdown dropdown-toggle">
                                    <i class="fa fa-book me-1"/>
                                    <t t-if="state.journal_ids.length === 0">All Journals</t>
                                    <t t-else="">Journals (<t t-esc="state.journal_ids.length"/>)</t>
                                </button>
                                <t t-set-slot="content">
                                    <t t-foreach="state.journals" t-as="journal" t-key="journal.id">
                                        <DropdownItem onSelected="() => this.onJournalChanged(journal.id)">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" t-att-checked="state.journal_ids.includes(journal.id)"/>
                                                <label class="form-check-label"><t t-esc="journal.code"/> - <t t-esc="journal.name"/></label>
                                            </div>
                                        </DropdownItem>
                                    </t>
                                </t>
                            </Dropdown>

                            <!-- Options Filter -->
                            <Dropdown>
                                <button class="btn btn-secondary o-dropdown dropdown-toggle">
                                    <i class="fa fa-sliders me-1"/> Options
                                </button>
                                <t t-set-slot="content">
                                    <DropdownItem onSelected="() => this.onTargetMoveChanged(state.target_move !== 'posted')">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" t-att-checked="state.target_move === 'posted'"/>
                                            <label class="form-check-label">Posted Entries Only</label>
                                        </div>
                                    </DropdownItem>
                                </t>
                            </Dropdown>
                        </div>
                    </div>
                </div>
            </div>

            <!-- REPORT CONTENT -->
            <div class="o_content flex-grow-1 overflow-auto bg-light">
                <div class="p-4 d-flex justify-content-center">
                    <div class="bg-white shadow-sm border p-4 w-100" style="max-width: 1140px;" t-if="state.data">
                        
                        <table class="table table-sm table-hover table-borderless">
                            <thead class="border-bottom">
                                <tr>
                                    <th></th>
                                    <th class="column_header text-end pb-2">Initial Balance</th>
                                    <th class="column_header text-center pb-2" colspan="2"><t t-esc="formatDate(state.date_to)"/></th>
                                    <th class="column_header text-end pb-2">End Balance</th>
                                </tr>
                                <tr class="text-muted">
                                    <th></th>
                                    <th class="text-end">Balance</th>
                                    <th class="text-end">Debit</th>
                                    <th class="text-end">Credit</th>
                                    <th class="text-end">Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.data.lines" t-as="line" t-key="line.id">
                                    <td class="ps-2">
                                        <span class="fw-bold"><t t-esc="line.code"/></span> <t t-esc="line.name"/>
                                    </td>
                                    <td class="text-end text-muted"><t t-esc="formatCurrency(line.initial_balance)"/></td>
                                    <td class="text-end"><t t-esc="formatCurrency(line.debit)"/></td>
                                    <td class="text-end"><t t-esc="formatCurrency(line.credit)"/></td>
                                    <td class="text-end fw-bold"><t t-esc="formatCurrency(line.ending_balance)"/></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>