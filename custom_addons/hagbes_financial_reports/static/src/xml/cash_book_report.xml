<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="CashBookTemp">
        <div class="o_account_reports_body" style="padding: 20px; background-color: white;">
            <div class="row mb-4">
                <div class="col-6">
                    <h2 class="mt0">Cash Book</h2>
                    <div class="text-muted">
                        From: <span t-esc="state.options.date_from"/> To: <span t-esc="state.options.date_to"/>
                    </div>
                </div>
                <div class="col-6 text-right">
                    <button class="btn btn-primary" t-on-click="print_pdf">Print PDF</button>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr class="thead-light">
                            <th>Date</th>
                            <th>JRNL</th>
                            <th>Partner</th>
                            <th>Ref</th>
                            <th>Move</th>
                            <th>Label</th>
                            <th class="text-right">Debit</th>
                            <th class="text-right">Credit</th>
                            <th class="text-right">Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.data.accounts" t-as="account" t-key="account.id">
                            <tr class="table-active font-weight-bold">
                                <td colspan="6">
                                    <t t-esc="account.code"/> - <t t-esc="account.name"/>
                                </td>
                                <td colspan="3" class="text-right">
                                    Initial Balance: <t t-esc="account.initial_balance"/>
                                </td>
                            </tr>
                            <tr t-foreach="account.lines" t-as="line" t-key="line.id">
                                <td><t t-esc="line.date"/></td>
                                <td><t t-esc="line.journal_code"/></td>
                                <td><t t-esc="line.partner_name"/></td>
                                <td><t t-esc="line.ref"/></td>
                                <td><t t-esc="line.move_name"/></td>
                                <td><t t-esc="line.name"/></td>
                                <td class="text-right"><t t-esc="line.debit"/></td>
                                <td class="text-right"><t t-esc="line.credit"/></td>
                                <td class="text-right"><t t-esc="line.balance"/></td>
                            </tr>
                            <tr class="font-weight-bold border-bottom">
                                <td colspan="8" class="text-right">Ending Balance</td>
                                <td class="text-right"><t t-esc="account.ending_balance"/></td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </div>
    </t>
</templates>