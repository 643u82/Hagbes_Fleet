<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_tax_report">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center">Tax Report</h2>
                    <div class="row mt32 mb32">
                        <div class="col-4">
                            <strong>Date From:</strong> <span t-esc="data.get('date_from')"/>
                        </div>
                        <div class="col-4">
                            <strong>Date To:</strong> <span t-esc="data.get('date_to')"/>
                        </div>
                    </div>

                    <h3 class="mt-4">Sales Tax</h3>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Tax Name</th>
                                <th class="text-right">Base Amount</th>
                                <th class="text-right">Tax Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="data['sales_tax']" t-as="line">
                                <td><span t-esc="line['name']"/></td>
                                <td class="text-right"><span t-esc="line['base']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
                                <td class="text-right"><span t-esc="line['amount']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <h3 class="mt-4">Purchase Tax</h3>
                    <table class="table table-sm table-striped">
                        <thead>
                            <tr>
                                <th>Tax Name</th>
                                <th class="text-right">Base Amount</th>
                                <th class="text-right">Tax Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="data['purchase_tax']" t-as="line">
                                <td><span t-esc="line['name']"/></td>
                                <td class="text-right"><span t-esc="line['base']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
                                <td class="text-right"><span t-esc="line['amount']" t-options="{'widget': 'monetary', 'display_currency': res_company.currency_id}"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="action_report_tax_report" model="ir.actions.report">
        <field name="name">Tax Report</field>
        <field name="model">report.custom_financial_reports.report_tax_report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_financial_reports.report_tax_report</field>
        <field name="report_file">custom_financial_reports.report_tax_report</field>
    </record>
</odoo>