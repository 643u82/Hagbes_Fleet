<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Client Action -->
    <record id="action_custom_cash_flow_client" model="ir.actions.client">
        <field name="name">Cash Flow Statement</field>
        <field name="tag">custom_financial_reports.cash_flow_client_action</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_custom_cash_flow"
              name="Cash Flow Statement"
              parent="account.menu_finance_reports"
              action="action_custom_cash_flow_client"
              sequence="30"/>

    <!-- Report Action -->
    <record id="action_report_cash_flow" model="ir.actions.report">
        <field name="name">Cash Flow Statement</field>
        <field name="model">custom.cash.flow.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_financial_reports.report_cash_flow</field>
        <field name="report_file">custom_financial_reports.report_cash_flow</field>
    </record>
</odoo>
