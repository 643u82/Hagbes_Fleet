<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.team.restriction</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <!-- Add domain and readonly based on computed field -->
            <xpath expr="//field[@name='user_id']" position="attributes">
                <attribute name="domain">[('id', 'in', allowed_assignees)]</attribute>
                <attribute name="readonly">user_id_readonly</attribute>
            </xpath>

            <!-- Show team_id only to System & Sales GM -->
            <xpath expr="//field[@name='user_id']" position="before">
                <field name="team_id"
                       groups="base.group_system,hagbes_crm_team_restriction.group_crm_sales_general_manager"/>
            </xpath>

            <!-- Make sure the computed field is in the view (invisible) -->
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="user_id_readonly" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>