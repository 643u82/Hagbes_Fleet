<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- CRM Root Menu: Shared by all three groups -->
    <record id="crm.crm_menu_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('hagbes_crm_team_restriction.group_operation_director'))]"/>
    </record>
    <!--parent menus-->
    <record id='crm.crm_menu_sales' model='ir.ui.menu'>
        <field name='groups_id' eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>
    <!--Menus for operational director-->
    <record id='crm.crm_menu_leads' model='ir.ui.menu'>
       <field name='groups_id' eval="[(4, ref('sales_team.group_sale_salesman'))]"/>
    </record>
    <record id='crm.crm_menu_report' model='ir.ui.menu'>
        <field name='groups_id' eval="[(4, ref('hagbes_crm_team_restriction.group_operation_director'))]"/>
    </record>
    
</odoo>
