    <record id="action_hr_leave_balance_report" model="ir.actions.act_window">
        <field name="name">Leave Balance Configuration</field>
        <field name="res_model">hr.leave.allocation</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_hr_leave_balance_list"/>
        <field name="target">current</field>

    </record>


    <menuitem id="menu_hr_leave_balance_report"
              name="Leave Balance Configuration"
              parent="hr_holidays.menu_hr_holidays_configuration"
              action="action_hr_leave_balance_report"/>


        <!-- Disable dashboard and management menus -->
        <record id="hr_holidays.menu_hr_holidays_dashboard" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <record id="hr_holidays.menu_hr_holidays_management" model="ir.ui.menu">
            <field name="active" eval="False"/>
        </record>

        <record id="hr_holidays.menu_hr_holidays_summary_all" model="ir.ui.menu">
            <field name="active">False</field>
        </record>
        <record id="hr_holidays.hr_holidays_accrual_menu_configuration" model="ir.ui.menu">
         <field name="active">False</field>
        </record>
        <record id="action_hr_leave_allocation_report" model="ir.actions.act_window">
            <field name="name">Allocation Report</field>
            <field name="res_model">hr.leave.allocation</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="hr_holidays.hr_leave_allocation_view_tree"/>
            <field name="target">current</field>
            <field name="domain">[('state','in',['approved','rejected','pending'])]</field>
        </record>
        <record id="view_holiday_list_inherit_branch_company" model="ir.ui.view">
            <field name="name">hr.holidays.report_list.inherit.branch.company</field>
            <field name="model">hr.leave</field>
            <field name="inherit_id" ref="hr_holidays.view_holiday_list"/>
            <field name="arch" type="xml">
                <!-- Add branch after employee_id -->
                <field name="employee_id" position="after">
                    <field name="employee_branch_id"/>
                    <field name="company_id" string="Company"/>
                </field>
            </field>
        </record>
        <record id="hr_leave_action_my" model="ir.actions.act_window">
            <field name="name">My Time Off</field>
            <field name="res_model">hr.leave</field>
            <field name="view_mode">list,form,kanban</field> <!-- optional but recommended -->
            <field name="domain">['|', ('user_id', '=', uid), ('requested_by_uid', '=', uid)]</field>
            <field name="context">
                {
                    "search_default_group_date_from": True,
                    "default_requested_by_id": uid
                }
            </field>
        </record>






    </data>
