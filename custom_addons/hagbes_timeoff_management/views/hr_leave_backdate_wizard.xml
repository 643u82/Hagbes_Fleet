<odoo>
    <data>
        <record id="view_hr_leave_backdate_wizard" model="ir.ui.view">
            <field name="name">hr.leave.backdate.wizard.form</field>
            <field name="model">hr.leave.backdate.wizard</field>
            <field name="arch" type="xml">
                <form string="New Backdate Request" class="o_form_lightbox">
                    <sheet>
                        <!-- Employee & Leave Type -->
                        <group>
                            <field name="employee_id" placeholder="Select Employee" options="{'no_create': True}"/>
                            <field name="holiday_status_id" placeholder="Select Leave Type" options="{'no_create': True}"/>
                        </group>


                        <!-- Half Day Checkbox -->
                        <group>
                            <field name="request_unit_half" widget="checkbox"/>
                        </group>

                        <!-- Full Day or Half Day Dates -->
                        <group>
                            <!-- Full day: show Start/End -->
                            <!-- Full day -->
                            <div class="o_row" invisible="request_unit_half">
                                <label for="request_date_from" string="Start Date"/>
                                <field name="request_date_from" widget="datetime" placeholder="From 08:00"/>
                                <label for="request_date_to" string="End Date"/>
                                <field name="request_date_to" widget="datetime" placeholder="To 17:00"/>
                            </div>

                            <!-- Half day -->
                            <div class="o_row" invisible="not request_unit_half">
                                <label for="request_date_from" string="Date"/>
                                <field name="request_date_from" widget="date"/>
                                <label for="request_date_from_period" string="Period"/>
                                <field name="request_date_from_period"/>
                            </div>

                        </group>

                        <!-- Number of days & reason -->
                        <group>
                            <field name="number_of_days" readonly="1" class="oe_highlight"/>
                            <field name="reason" placeholder="Reason for backdate leave"/>
                        </group>
                        <group>
                            <field name="supported_attachment_ids" widget="many2many_binary"
                                   options="{'no_create': True}" placeholder="Attach supporting documents"/>
                        </group>

                    </sheet>

                    <footer>
                        <button string="Submit"
                                type="object"
                                name="action_submit"
                                class="btn btn-primary"/>
                        <button string="Cancel"
                                class="btn btn-secondary"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>