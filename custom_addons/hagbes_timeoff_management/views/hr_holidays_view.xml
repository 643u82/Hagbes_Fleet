<odoo>

    <!-- Popup action for Delegate User -->
    <record id="action_approval_delegate_form_popup" model="ir.actions.act_window">
        <field name="name">Approval Delegation</field>
        <field name="res_model">approval.delegate</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="hagbes_approval_workflow.view_approval_delegate_form"/>
        <field name="target">new</field>
    </record>

    <!-- Inherit and customize Leave form -->
    <record id="hr_leave_view_form_buttons_inherit" model="ir.ui.view">
        <field name="name">hr.leave.view.form.buttons.inherit</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">


            <!-- Replace header buttons -->
            <xpath expr="//header" position="replace">
                <header>
                    <button string="Approve" name="action_approve" type="object"
                            class="oe_highlight btn btn-success"
                            confirm="Are you sure you want to approve this leave?"
                            invisible="can_approve == False"/>

                    <button string="Reject" name="action_reject" type="object"
                            class="oe_highlight btn btn-danger"
                            confirm="Are you sure you want to reject this leave?"
                            invisible="can_approve == False"/>

                    <button name="action_open_update_wizard"
                            type="object"
                            string="Update Data"
                            class="btn-primary"
                            groups="hagbes_approval_workflow.group_approval_hr"
                            invisible="can_approve == False"/>
                </header>
            </xpath>

            <!-- Add Requested By field -->
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="requested_by_id" readonly="1"
                       invisible="not (state in ('pending','approved','rejected'))"/>
            </xpath>
            <xpath expr="//group[@name='col_left']" position="inside">
                <field name="employee_id" readonly="1" invisible="not (state in ('pending','approved','rejected'))"/>
                <field name="is_backdate" readonly="1" invisible="not (state in ('pending','approved','rejected'))"/>
            </xpath>

            <!-- Change label of Reason -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="string">Reason</attribute>
            </xpath>

            <!-- Make all fields in sheet readonly when state is pending, approved, or rejected -->
            <xpath expr="//sheet" position="attributes">
                <attribute name="readonly">state in ['pending','approved','rejected']</attribute>
                <attribute name="options">{'no_open': True}</attribute>
            </xpath>



            <xpath expr="//field[@name='holiday_status_id']" position="attributes">
                <attribute name="readonly">state in ['pending','approved','rejected']</attribute>
            </xpath>






            <!-- Add Delegate User button -->
            <xpath expr="//sheet" position="inside">
                <button name="%(action_approval_delegate_form_popup)d"
                        type="action"
                        string="Delegate User"
                        class="btn-secondary"
                        groups="hagbes_approval_workflow.group_approval_dept_manager,
                                hagbes_approval_workflow.group_approval_gm,
                                hagbes_approval_workflow.group_approval_director,
                                hagbes_approval_workflow.group_approval_md,
                                hagbes_approval_workflow.group_approval_owner,
                                hagbes_approval_workflow.group_approval_hr,
                                hagbes_approval_workflow.group_approval_hr_gm"
                        invisible="state in ['pending','approved','rejected']"/>
            </xpath>

            <xpath expr="//sheet" position="inside" class="o_green_group">
                <group string="Available Yearly Balances" class="o_green_group" colspan="2"
                    invisible="not (state in ('pending','approved','rejected'))">
                    <group>
                        <field name="leave_balance_year_2" readonly="1"/>
                    </group>
                    <group>
                        <field name="leave_balance_year_1" readonly="1"/>
                    </group>
                    <group>
                        <field name="current_year_balance" readonly="1"/>
                    </group>
                    <group>
                        <field name="total_leave_balance" readonly="1"/>
                    </group>
                </group>
            </xpath>
            <xpath expr="//sheet" position="inside">
                <div class="o_form_footer o_notebook">
                    <field name="step_progress" widget="html" readonly="1"/>
                </div>
            </xpath>


        </field>
    </record>
    <record id="hr_leave_view_form_employee_readonly" model="ir.ui.view">
        <field name="name">hr.leave.view.form.employee.readonly</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form_manager"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="attributes">
                <attribute name="readonly">state in ['pending','approved','rejected']</attribute>
                <attribute name="options">{'no_open': True}</attribute>
                <attribute name="create">false</attribute>
            </xpath>

           <xpath expr="//field[@name='employee_id' and @widget='many2one_avatar_user']" position="attributes">
                <attribute name="readonly">1</attribute>
            </xpath>



            <!-- Optional: Make description field readonly -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="readonly">state in ['pending','approved','rejected']</attribute>
            </xpath>
            <xpath expr="//div[contains(@class, 'o_hr_leave_column') and contains(@class, 'col_right')]" position="attributes">
                    <attribute name="class">d-none</attribute>
            </xpath>

        </field>
    </record>

</odoo>
