<odoo>
    <!-- Override normal tree view: disable create/edit -->
    <record id="view_holiday_status_normal_tree" model="ir.ui.view">
        <field name="name">hr.leave.type.normal.list.override</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.view_holiday_status_normal_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="attributes">
                <attribute name="create">false</attribute>
                <attribute name="edit">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>

    <!-- Override kanban view: disable create/edit -->
    <record id="hr_holiday_status_view_kanban" model="ir.ui.view">
        <field name="name">hr.leave.type.kanban.override</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.hr_holiday_status_view_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//kanban" position="attributes">
                <attribute name="create">false</attribute>
                <attribute name="edit">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>
    <record id="edit_holiday_status_form_readonly" model="ir.ui.view">
        <field name="name">hr.leave.type.form.readonly.override</field>
        <field name="model">hr.leave.type</field>
        <field name="inherit_id" ref="hr_holidays.edit_holiday_status_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="attributes">
                <attribute name="edit">false</attribute>
                <attribute name="create">false</attribute>
                <attribute name="delete">false</attribute>
            </xpath>
        </field>
    </record>
</odoo>
