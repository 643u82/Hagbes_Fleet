<odoo>
    <!-- Allow Time Off Approver to see all leaves -->
    <record id="hr_leave_approver_rule" model="ir.rule">
        <field name="name">Time Off Approver: read all leaves</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('hagbes_timeoff_management.group_timeoff_approver'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="hr_leave_allocation_company_rule" model="ir.rule">
    <field name="name">HR Leave Allocation by Allowed Company</field>
    <field name="model_id" ref="hr_holidays.model_hr_leave_allocation"/>
    <field name="domain_force">[('employee_company_id','in',user.company_ids.ids), ('branch_id', 'in', user.allowed_branch_ids.ids)]</field>
    </record>
    <record id="hr_leave_report_rule_multi_company" model="ir.rule">
        <field name="name">Time Off : multi company global rule</field>
        <field name="model_id" ref="hr_holidays.model_hr_leave"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids ),
             ('employee_branch_id', 'in', user.allowed_branch_ids.ids)]
        </field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="hr_leave_report_rule_allowed_branches" model="ir.rule">
        <field name="name">Time Off Report: Allowed Branches</field>
        <field name="model_id" ref="model_hr_leave_employee_type_report"/>
        <field name="domain_force">[('company_id','in',user.company_ids.ids), ('branch_id', 'in', user.allowed_branch_ids.ids)]</field>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>



</odoo>
