<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-inherit="hr_holidays.TimeOffDashboard" t-inherit-mode="primary">
        <!-- Remove Pending Requests + Allocation block -->
        <xpath expr="//div[contains(@class,'o_timeoff_card')]" position="replace">
            <div class="o_timeoff_card p-0 d-flex flex-column align-items-stretch">
                <!-- Balances header (Year -2, Year -1, Current, Total) -->
                <div class="o_timeoff_dashboard_header d-flex justify-content-around align-items-center w-100 p-2">
                    <div class="o_stat_box text-center">
                        <div class="o_stat_value fw-bold fs-4" t-esc="state && state.my_custom_field_1 != null ? state.my_custom_field_1.toFixed(1) : '0.0'"></div>
                        <div class="o_stat_label text-muted" t-esc="state && state.my_custom_label_year2 ? state.my_custom_label_year2 : 'Year -2 Balance'"></div>
                    </div>
                    <div class="o_stat_box text-center">
                        <div class="o_stat_value fw-bold fs-4" t-esc="state && state.my_custom_field_2 != null ? state.my_custom_field_2.toFixed(1) : '0.0'"></div>
                        <div class="o_stat_label text-muted" t-esc="state && state.my_custom_label_year1 ? state.my_custom_label_year1 : 'Year -1 Balance'"></div>
                    </div>
                    <div class="o_stat_box text-center">
                        <div class="o_stat_value fw-bold fs-4" t-esc="state && state.my_custom_field_3 != null ? state.my_custom_field_3.toFixed(1) : '0.0'"></div>
                        <div class="o_stat_label text-muted" t-esc="state && state.my_custom_label_current ? state.my_custom_label_current : 'Current Year'"></div>
                    </div>
                    <div class="o_stat_box text-center">
                        <div class="o_stat_value fw-bold fs-4 text-success" t-esc="state && state.my_custom_field_4 != null ? state.my_custom_field_4.toFixed(1) : '0.0'"></div>
                        <div class="o_stat_label text-muted">Total Balance</div>
                    </div>
                </div>

                <!-- Custom stat cards -->
                <div class="d-flex justify-content-around align-items-center w-100 p-2">
                    <div class="d-flex flex-column justify-content-center align-items-center w-100">
                        <strong class="o_timeoff_name">Annual Leave</strong>
                        <span class="o_timeoff_duration" t-esc="state.my_custom_field_1"/>
                    </div>
                    <div class="d-flex flex-column justify-content-center align-items-center w-100">
                        <strong class="o_timeoff_name">Marriage Leave</strong>
                        <span class="o_timeoff_duration" t-esc="state.my_custom_field_2"/>
                    </div>
                    <div class="d-flex flex-column justify-content-center align-items-center w-100">
                        <strong class="o_timeoff_name">Sick Leave</strong>
                        <span class="o_timeoff_duration" t-esc="state.my_custom_field_3"/>
                    </div>
                    <div class="d-flex flex-column justify-content-center align-items-center w-100">
                        <strong class="o_timeoff_name">Maternity/Paternity</strong>
                        <span class="o_timeoff_duration" t-esc="state.my_custom_field_4"/>
                    </div>
                </div>
            </div>
        </xpath>
    </t>
</templates>
