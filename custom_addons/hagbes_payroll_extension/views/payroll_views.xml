<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_custom_payslip_list" model="ir.ui.view">
        <field name="name">custom.payslip.list</field>
        <field name="model">custom.payslip</field>
        <field name="arch" type="xml">
            <list string="Payslips">
                <!-- <field name="employee_id"/>
                <field name="job_id"/>
                <field name="department_id"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="basic_salary"/>
                <field name="net_salary"/> -->
                 <field name="employee_id"/>
                <field name="contract_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="basic_salary"/>
                <field name="salary_increment"/>
                <field name="updated_basic_salary"/>
                <field name="pension_employee"/>
                <field name="pension_employer"/>
                <field name="provident_fund"/>
                <field name="normal_hours"/>
                <field name="weekend_hours"/>
                <field name="holiday_hours"/>
                <field name="overtime_hours"/>
                <field name="transport_allowance"/>
                <field name="taxable_transport_allowance"/>
                <field name="mobile_allowance"/>
                <field name="housing_allowance"/>
                <field name="representation_allowance"/>
                <field name="absent_deduction"/>
                <field name="court_cost_lost_item"/>
                <field name="fine"/>
                <field name="loan_deduction"/>
                <field name="medical_deduction"/>
                <field name="income_tax"/>
                <field name="employer_contribution"/>
                <field name="employee_contribution"/>
                <field name="gross_pay"/>
                <field name="total_deduction"/>
                <field name="net_salary"/>
            </list>
        </field>
        <field name="type">list</field>
    </record>

    <record id="view_custom_payslip_form" model="ir.ui.view">
        <field name="name">custom.payslip.form</field>
        <field name="model">custom.payslip</field>
        <field name="arch" type="xml">
            <form string="Custom Payslip">
                <sheet>
                    <h1 class="oe_title">
                        <field name="employee_id" placeholder="employee name"/>
                    </h1>

                    <group>
                        <group string="General Info">
                            <field name="contract_id"/>
                            <field name="job_id"/>
                            <field name="department_id"/>
                            <field name="company_id"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Salary">
                            <group>
                                <field name="basic_salary"/>
                                <field name="salary_increment"/>
                                <field name="updated_basic_salary"/>
                                <field name="gross_pay"/>
                                <field name="net_salary"/>
                            </group>
                        </page>

                        <page string="Allowances">
                            <group>
                                <field name="transport_allowance"/>
                                <field name="taxable_transport_allowance"/>
                                <field name="mobile_allowance"/>
                                <field name="housing_allowance"/>
                                <field name="representation_allowance"/>
                            </group>
                        </page>

                        <page string="Work Details">
                            <group>
                                <field name="normal_hours"/>
                                <field name="weekend_hours"/>
                                <field name="holiday_hours"/>
                                <field name="overtime_hours"/>
                            </group>
                        </page>

                        <page string="Deductions">
                            <group>
                                <field name="absent_deduction"/>
                                <field name="court_cost_lost_item"/>
                                <field name="fine"/>
                                <field name="loan_deduction"/>
                                <field name="medical_deduction"/>
                                <field name="income_tax"/>
                                <field name="total_deduction"/>
                            </group>
                        </page>

                        <page string="Pension &amp; Contributions">
                            <group>
                                <field name="pension_employee"/>
                                <field name="pension_employer"/>
                                <field name="provident_fund"/>
                                <field name="employer_contribution"/>
                                <field name="employee_contribution"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
        <field name="type">form</field>
    </record>
    

    <record id="action_custom_payslip" model="ir.actions.act_window">
        <field name="name">Payslips</field>
        <field name="res_model">custom.payslip</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hagbes_payroll_extension_root" name="Payroll"/>

    <menuitem id="menu_custom_payslip" name="Payslips" parent="menu_hagbes_payroll_extension_root" action="action_custom_payslip"/>
</odoo>
